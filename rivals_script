-- ═══════════════════════════════════════════════════════
--  Math Utilities
-- ═══════════════════════════════════════════════════════

local function _wrapAngle(_a)
    return ((_a + math.pi) % _TAU) - math.pi
end

local function _lerpAngle(_from, _to, _speed)
    return _from + _wrapAngle(_to - _from) * _speed
end

-- ═══════════════════════════════════════════════════════
--  Camera Rotation Helper
-- ═══════════════════════════════════════════════════════

local function _rotateCameraToward(_targetPos, _smooth, _origin)
    _smooth = math.clamp(_smooth or 0.5, 0.01, 1)

    if _CamController and _CamController.SetRotation and _CamController.Rotation then
        local _cam = workspace.CurrentCamera
        _origin = _origin or (function()
            local _mc = _ActiveUser.Character
            local _mh = _mc and _mc:FindFirstChild("HumanoidRootPart")
            return _mh and (_mh.Position + Vector3.new(0, 1.5, 0))
                or (_cam and _cam.CFrame.Position)
        end)()

        if not _origin then return end

        local _dir = _targetPos - _origin
        local _hDist = math.sqrt(_dir.X * _dir.X + _dir.Z * _dir.Z)
        local _goalYaw   = math.atan2(-_dir.X, -_dir.Z)
        local _goalPitch = math.atan2(_dir.Y, _hDist)
        local _cur = _CamController.Rotation

        pcall(function()
            _CamController:SetRotation(Vector2.new(
                _cur.X + (_goalPitch - _cur.X) * _smooth,
                _lerpAngle(_cur.Y, _goalYaw, _smooth)
            ))
        end)
    else
        return
    end
end

-- ═══════════════════════════════════════════════════════
--  Character Utility Functions
-- ═══════════════════════════════════════════════════════

local function _getRootPart(_char)
    return _char and _char:FindFirstChild("HumanoidRootPart")
end

local function _getReferencePart(_char)
    if not _char then return nil end
    if _Prefs.AimPart == 1 then
        return _char:FindFirstChild("Head")
            or _char:FindFirstChild("HumanoidRootPart")
    elseif _Prefs.AimPart == 2 then
        return _char:FindFirstChild("HumanoidRootPart")
    else
        return _char:FindFirstChild("UpperTorso")
            or _char:FindFirstChild("Torso")
            or _char:FindFirstChild("HumanoidRootPart")
    end
end

local function _isFirstPerson()
    local _cam = workspace.CurrentCamera
    if not _cam then return false end
    local _mc = _ActiveUser.Character
    if not _mc then return false end

    local _head = _mc:FindFirstChild("Head")
    if _head and (_cam.CFrame.Position - _head.Position).Magnitude < 2 then
        return true
    end

    local _hrp = _mc:FindFirstChild("HumanoidRootPart")
    if _hrp and (_cam.CFrame.Position - _hrp.Position).Magnitude < 3 then
        return true
    end

    return false
end

local function _isPartVisible(_part, _myChar)
    if not _part then return false end
    local _cam = workspace.CurrentCamera
    if not _cam then return true end
    _myChar = _myChar or _ActiveUser.Character

    local _origin = _cam.CFrame.Position
    local _dir = _part.Position - _origin
    if _dir.Magnitude < 0.5 then return true end

    local _rayParams = RaycastParams.new()
    _rayParams.FilterType = Enum.RaycastFilterType.Exclude
    _rayParams.FilterDescendantsInstances = _myChar and {_myChar} or {}

    local _hit = workspace:Raycast(_origin, _dir * 0.999, _rayParams)
    if not _hit then return true end

    local _inst = _hit.Instance
    while _inst do
        if _inst == _part.Parent then return true end
        _inst = _inst.Parent
    end
    return false
end

-- ═══════════════════════════════════════════════════════
--  Grounded check for bhop
-- ═══════════════════════════════════════════════════════

local function _isGrounded(_char)
    if not _char then return false end
    local _hrp = _char:FindFirstChild("HumanoidRootPart")
    if not _hrp then return false end

    local _rayParams = RaycastParams.new()
    _rayParams.FilterType = Enum.RaycastFilterType.Exclude
    _rayParams.FilterDescendantsInstances = {_char}

    local _hit = workspace:Raycast(_hrp.Position, Vector3.new(0, -3.5, 0), _rayParams)
    return _hit ~= nil
end

-- ═══════════════════════════════════════════════════════
--  Motion Prediction
-- ═══════════════════════════════════════════════════════

local function _getPredictedPosition(_target, _dt)
    if not _Prefs.AimPrediction or not _target or not _target.part then
        return _target and _target.part and _target.part.Position
    end

    local _pos = _target.part.Position
    local _id = _target.char and tostring(_target.char) or ""
    local _prev = _motionHistory[_id]

    if _prev then
        local _velocity = (_pos - _prev.pos) / math.max(_prev.dt, 0.001)
        local _cam = workspace.CurrentCamera
        local _dist = _cam and (_cam.CFrame.Position - _pos).Magnitude or 100
        local _distFactor = math.clamp(_dist / 200, 0.5, 2)

        _motionHistory[_id] = {pos = _pos, dt = _dt, time = os.clock()}
        return _pos + _velocity * _Prefs.PredictionStrength * _distFactor
    else
        _motionHistory[_id] = {pos = _pos, dt = _dt, time = os.clock()}
        return _pos
    end
end

local function _cleanupMotionHistory()
    local _count = 0
    for _ in pairs(_motionHistory) do _count = _count + 1 end

    if _count > 100 then
        local _stale = {}
        for _id, _data in pairs(_motionHistory) do
            if os.clock() - (_data.time or 0) > 5 then
                table.insert(_stale, _id)
            end
        end
        for _, _id in ipairs(_stale) do
            _motionHistory[_id] = nil
        end
    end

    local _now = os.clock()
    for _id, _data in pairs(_smoothCache) do
        if _now - (_data.t or 0) > 3 then
            _smoothCache[_id] = nil
        end
    end
end

-- ═══════════════════════════════════════════════════════
--  Team Affiliation Check
-- ═══════════════════════════════════════════════════════

local function _isAllied(_player, _entity)
    if not _Prefs.TeamCheck then return false end

    if _entity and _FighterController and _FighterController.LocalFighter then
        local _ok, _result = pcall(function()
            local _localFighter = _FighterController.LocalFighter
            if type(_entity) ~= "table" or type(_entity.Get) ~= "function" then return false end
            if type(_localFighter.Get) ~= "function" then return false end

            local _eTeam = _entity:Get("TeamID")
            local _lTeam = _localFighter:Get("TeamID")
            if _lTeam and _eTeam and _lTeam == _eTeam then return true end

            local _eEnv = _entity:Get("EnvironmentID")
            local _lEnv = _localFighter:Get("EnvironmentID")
            if _lEnv and _eEnv and _lEnv ~= _eEnv then return true end

            local _eDuel = _entity:Get("DuelID") or _entity:Get("MatchID")
            local _lDuel = _localFighter:Get("DuelID") or _localFighter:Get("MatchID")
            if _lDuel and _eDuel and _lDuel ~= _eDuel then return true end

            local _eState = _entity:Get("State") or _entity:Get("CombatState")
            if _eState and (_eState == "Dead" or _eState == "Downed" or _eState == "Spectating") then
                return true
            end

            return false
        end)
        if _ok and _result then return true end
    end

    if _player and typeof(_player) == "Instance" and _player:IsA("Player") then
        if _player.Team and _ActiveUser.Team and _player.Team == _ActiveUser.Team then
            return true
        end
    end

    return false
end

-- ═══════════════════════════════════════════════════════
--  Session Kill Tracking
-- ═══════════════════════════════════════════════════════

local function _updateSessionKills()
    for _, _p in ipairs(_PlayerService:GetPlayers()) do
        if _p ~= _ActiveUser then
            pcall(function()
                local _char = _p.Character
                if not _char then return end
                local _hum = _char:FindFirstChildOfClass("Humanoid")
                if not _hum then
                    _healthTracker[_p.UserId] = nil
                    return
                end

                local _prevHP = _healthTracker[_p.UserId]
                if _prevHP and _prevHP > 1 and _hum.Health <= 0 then
                    if _currentAimTarget and _currentAimTarget.char == _char then
                        _sessionKills = _sessionKills + 1
                        _Renderer.NotifyKill(_p.DisplayName or _p.Name)
                    end
                end

                _healthTracker[_p.UserId] = _hum.Health > 0 and _hum.Health or nil
            end)
        end
    end
end

_PlayerService.PlayerRemoving:Connect(function(_p)
    _healthTracker[_p.UserId] = nil
end)

-- ═══════════════════════════════════════════════════════
--  Camera Assist
-- ═══════════════════════════════════════════════════════

local function _applyCameraAssist(_targetPos, _dt)
    if _Prefs.FirstPersonOnly and not _isFirstPerson() then return end
    if _Renderer.isOpen then return end

    local _cam = workspace.CurrentCamera
    if not _cam then return end

    local _dist = (_cam.CFrame.Position - _targetPos).Magnitude
    if _dist > _Prefs.AimRange then return end

    local _screenPos, _onScreen = _cam:WorldToViewportPoint(_targetPos)
    if not _onScreen then return end

    local _cx, _cy = _Renderer.getCenter()
    local _screenDist = math.sqrt((_screenPos.X - _cx) ^ 2 + (_screenPos.Y - _cy) ^ 2)
    if _screenDist > _Prefs.FOV then return end

    local _dtNorm = math.clamp(_dt * 60, 0.3, 4)
    local _baseSpeed = _Prefs.AimSpeed / 10
    local _smoothInv = 1 - _Prefs.SmoothFactor
    local _distFactor = math.clamp(1 - (_dist / _Prefs.AimRange) * 0.2, 0.6, 1)
    local _centerFactor = math.clamp(1 - (_screenDist / _Prefs.FOV) * 0.3, 0.7, 1)

    local _smoothVal = math.clamp(
        _baseSpeed * _smoothInv * _dtNorm * _distFactor * _centerFactor,
        0.03, 0.95
    )

    _rotateCameraToward(_targetPos, _smoothVal, _cam.CFrame.Position)
end

-- ═══════════════════════════════════════════════════════
--  Target Enumeration
-- ═══════════════════════════════════════════════════════

local function _enumerateTargets()
    local _targets = {}

    local _success, _err = _SafeInvoke("enumerateTargets", function()
        if _FighterController then
            pcall(function()
                local _localFighter = _FighterController.LocalFighter
                for _, _fighter in pairs(_FighterController.Objects) do
                    pcall(function()
                        if _fighter == _localFighter then return end
                        if not _fighter.Entity or not _fighter.Entity.RootPart then return end

                        local _hum = _fighter.Entity.Humanoid
                        if not _hum or _hum.Health <= 0 then return end

                        local _pl = _fighter.Entity.Player
                        if _isAllied(_pl, _fighter) then return end

                        local _char = _fighter.Entity.RootPart.Parent
                        local _refPart = _getReferencePart(_char) or _fighter.Entity.RootPart

                        _targets[#_targets + 1] = {
                            part     = _refPart,
                            hum      = _hum,
                            char     = _char,
                            hrp      = _fighter.Entity.RootPart,
                            name     = _pl and (_pl.DisplayName or _pl.Name)
                                       or (_char and _char.Name) or "?",
                            isPlayer = true,
                            player   = _pl
                        }
                    end)
                end
            end)
        else
            for _, _p in ipairs(_PlayerService:GetPlayers()) do
                if _p ~= _ActiveUser and not _isAllied(_p) then
                    pcall(function()
                        local _char = _p.Character
                        if not _char or not _char.Parent then return end
                        local _hrp = _char:FindFirstChild("HumanoidRootPart")
                        if not _hrp then return end
                        local _hum = _char:FindFirstChildOfClass("Humanoid")
                        if not _hum or _hum.Health <= 0 then return end
                        local _refPart = _getReferencePart(_char)
                        if not _refPart then return end

                        _targets[#_targets + 1] = {
                            part     = _refPart,
                            hum      = _hum,
                            char     = _char,
                            hrp      = _hrp,
                            name     = _p.DisplayName or _p.Name,
                            isPlayer = true,
                            player   = _p
                        }
                    end)
                end
            end
        end

        if _EntityController then
            pcall(function()
                for _, _npc in pairs(_EntityController.Objects) do
                    pcall(function()
                        if not _npc.Entity or not _npc.Entity.RootPart then return end
                        local _hum = _npc.Entity.Humanoid
                        if not _hum or _hum.Health <= 0 then return end

                        local _char = _npc.Entity.RootPart.Parent
                        local _refPart = _getReferencePart(_char) or _npc.Entity.RootPart

                        _targets[#_targets + 1] = {
                            part     = _refPart,
                            hum      = _hum,
                            char     = _char,
                            hrp      = _npc.Entity.RootPart,
                            name     = _char and _char.Name or "NPC",
                            isPlayer = false
                        }
                    end)
                end
            end)
        end
    end)

    if not _success then
        _DiagLog:Add("enumerateTargets", _err)
    end

    return _targets
end

-- ═══════════════════════════════════════════════════════
--  Target Selection
-- ═══════════════════════════════════════════════════════

local function _findClosestTarget(_targets, _dt)
    local _cam = workspace.CurrentCamera
    if not _cam then return nil end

    local _cx, _cy = _Renderer.getCenter()
    local _camPos = _cam.CFrame.Position

    if _Prefs.StickTarget and _lockedTarget then
        for _, _t in ipairs(_targets) do
            if _t.char == _lockedTarget.char
               and _t.part and _t.part.Parent
               and _t.hum and _t.hum.Health > 0
               and (_camPos - _t.part.Position).Magnitude <= _Prefs.AimRange then
                return _t
            end
        end
        _lockedTarget = nil
    end

    local _best, _bestScore = nil, 9999
    for _, _t in ipairs(_targets) do
        if _t.part and _t.part.Parent then
            local _worldDist = (_camPos - _t.part.Position).Magnitude
            if _worldDist <= _Prefs.AimRange then
                local _sp, _on = _cam:WorldToViewportPoint(_t.part.Position)
                if _on then
                    local _screenDist = math.sqrt((_sp.X - _cx) ^ 2 + (_sp.Y - _cy) ^ 2)
                    if _screenDist <= _Prefs.FOV then
                        if not _Prefs.AimVisCheck or _isPartVisible(_t.part) then
                            local _hpFactor = 1
                            if _t.hum and _t.hum.MaxHealth > 0 then
                                _hpFactor = _t.hum.Health / _t.hum.MaxHealth
                            end
                            local _score = _screenDist * (0.5 + _hpFactor * 0.5)
                            if _score < _bestScore then
                                _bestScore = _score
                                _best = _t
                            end
                        end
                    end
                end
            end
        end
    end

    if _best and _Prefs.StickTarget then
        _lockedTarget = _best
    end

    return _best
end

-- ═══════════════════════════════════════════════════════
--  Bunny Hop System
-- ═══════════════════════════════════════════════════════

local function _updateBhop(_dt)
    if not _Prefs.BhopEnabled then return end

    local _mc = _ActiveUser.Character
    if not _mc then return end
    local _hum = _mc:FindFirstChildOfClass("Humanoid")
    if not _hum or _hum.Health <= 0 then return end
    local _mh = _getRootPart(_mc)
    if not _mh then return end

    local _moveDir = _hum.MoveDirection
    if _moveDir.Magnitude < 0.1 then return end

    if not _isGrounded(_mc) then return end

    local _now = os.clock()
    local _delay = math.max(_Prefs.BhopJumpDelay or 0.12, 0.05)
    if (_now - _lastBhopTime) < _delay then return end

    _lastBhopTime = _now
    pcall(function()
        _hum:ChangeState(Enum.HumanoidStateType.Jumping)
    end)
end

