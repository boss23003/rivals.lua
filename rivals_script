_Renderer.makeButton(5, "Import Config", function()
    _Renderer.Notify("Config", "Enter Base64 string in chat", 3)
    local _chatConn
    _chatConn = _ActiveUser.Chatted:Connect(function(_msg)
        if _msg:find("CFG-MOON-") then
            pcall(function()
                local _raw = _msg:gsub("CFG-MOON-", "")
                local _decoded = _DataSerializer:JSONDecode(_fromBase64(_raw))
                if _decoded.CFG then
                    for _k, _v in pairs(_decoded.CFG) do
                        if _Prefs[_k] ~= nil then
                            _Prefs[_k] = _v
                        end
                    end
                    if _decoded.UI then
                        for _k, _v in pairs(_decoded.UI) do _Renderer.UIConfigs[_k] = _v end
                    end
                    pcall(function() _Renderer.removeAllChams() end)
                    _Renderer.Notify("Config", "Configuration imported!", 3, Color3.fromRGB(100, 255, 100))
                    _savePrefs()
                end
            end)
            _chatConn:Disconnect()
        end
    end)
    task.delay(10, function() if _chatConn then _chatConn:Disconnect() end end)
end)

