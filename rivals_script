-- ═══════════════════════════════════════════════════════
--  Diagnostic Logger
-- ═══════════════════════════════════════════════════════

local _DiagLog = {
    entries   = {},
    maxEntries = 50
}

function _DiagLog:Add(_context, _err)
    table.insert(self.entries, 1, {
        time    = os.clock(),
        context = _context,
        error   = tostring(_err)
    })
    while #self.entries > self.maxEntries do
        table.remove(self.entries)
    end
    warn(string.format("[TOOLKIT DIAG] %s: %s", _context, tostring(_err)))
end

function _DiagLog:GetLines(_maxCount)
    _maxCount = _maxCount or 10
    local _out = {}
    for _i, _entry in ipairs(self.entries) do
        if _i > _maxCount then break end
        local _line = string.format(
            "[%.1f] %s: %s",
            _entry.time or 0,
            tostring(_entry.context or "?"),
            tostring(_entry.error or "?")
        )
        table.insert(_out, _line)
    end
    return _out
end

local function _SafeInvoke(_context, _func, ...)
    local _success, _result = pcall(_func, ...)
    if not _success then
        _DiagLog:Add(_context, _result)
    end
    return _success, _result
end

-- ═══════════════════════════════════════════════════════
--  Instance Lifecycle Tracker
-- ═══════════════════════════════════════════════════════

local _LifecycleTracker = {
    tracked      = {},
    cleanupQueue = {}
}

function _LifecycleTracker:Track(_obj, _name)
    if _obj then
        self.tracked[tostring(_obj)] = {
            obj  = _obj,
            name = _name,
            time = os.clock()
        }
    end
end

function _LifecycleTracker:Cleanup()
    for _id, _entry in pairs(self.tracked) do
        if not _entry.obj or not _entry.obj.Parent then
            self.tracked[_id] = nil
        end
    end
end

