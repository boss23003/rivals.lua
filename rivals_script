-- ═══════════════════════════════════════════════════════
--  O B F U S C A T E D  &  I M P R O V E D  T R I G G E R B O T
--  [0x00A1] Max precision algorithm (Rage Mode compatible)
-- ═══════════════════════════════════════════════════════

local function _0xT1_ProjBounds(_c, _p, _x, _y)
    local _s, _cf = _p.Size, _p.CFrame
    local _hX, _hY, _hZ = _s.X * 0.5, _s.Y * 0.5, _s.Z * 0.5
    local _verts = {
        _cf * Vector3.new(-_hX, -_hY, -_hZ), _cf * Vector3.new( _hX, -_hY, -_hZ),
        _cf * Vector3.new(-_hX,  _hY, -_hZ), _cf * Vector3.new( _hX,  _hY, -_hZ),
        _cf * Vector3.new(-_hX, -_hY,  _hZ), _cf * Vector3.new( _hX, -_hY,  _hZ),
        _cf * Vector3.new(-_hX,  _hY,  _hZ), _cf * Vector3.new( _hX,  _hY,  _hZ),
    }
    local _mX, _mY, _mXX, _mYY = math.huge, math.huge, -math.huge, -math.huge
    for _, _v in ipairs(_verts) do
        local _sp, _os = _c:WorldToViewportPoint(_v)
        if not _os then return false end
        if _sp.X < _mX then _mX = _sp.X end
        if _sp.X > _mXX then _mXX = _sp.X end
        if _sp.Y < _mY then _mY = _sp.Y end
        if _sp.Y > _mYY then _mYY = _sp.Y end
    end
    return _x >= _mX and _x <= _mXX and _y >= _mY and _y <= _mYY
end

local function _0xT2_GetHitboxes(_ch)
    if not _ch then return {} end
    local _p = {}
    for _, _v in ipairs(_ch:GetDescendants()) do
        if _v:IsA("BasePart") and _v.Transparency < 1 and _v.Name ~= "HumanoidRootPart" then
            _p[#_p+1] = _v
        end
    end
    return _p
end

local function _runAutoInteraction(_targets)
    if not _Prefs.Triggerbot then return end
    if _Prefs.FirstPersonOnly and not _isFirstPerson() then return end

    local _cam = workspace.CurrentCamera
    if not _cam then return end

    local _n = os.clock()
    if _n - _lastAutoTime < (_Prefs.TrigBotDelay or 0.10) then return end

    local _mc = _ActiveUser.Character
    local _cp = _cam.CFrame.Position
    local _md = _Prefs.TrigBotMaxDist or _Prefs.AimRange or 200
    local _cx, _cy = _Renderer.getCenter()

    local _cMap = {}
    for _, _t in ipairs(_targets) do
        if _t.char and _t.char.Parent and _t.hum and _t.hum.Health > 0 then
            local _wd = _t.hrp and (_cp - _t.hrp.Position).Magnitude or 9999
            if _wd <= _md then _cMap[_t.char] = _t end
        end
    end

    local _rp = RaycastParams.new()
    _rp.FilterType = Enum.RaycastFilterType.Exclude
    _rp.FilterDescendantsInstances = _mc and {_mc} or {}

    local _hit = workspace:Raycast(_cp, _cam.CFrame.LookVector * _md, _rp)
    if _hit and _hit.Instance then
        local _chk = _hit.Instance
        while _chk do
            if _cMap[_chk] then
                _lastAutoTime = _n
                _hitFeedbackTime = _n
                pcall(_simulateInteraction)
                return
            end
            _chk = _chk.Parent
        end
    end

    -- Secondary check for micro-gaps / lag compensation
    local _radiusCheck = _Renderer.isRageMode and 15 or 0 
    for _ch, _t in pairs(_cMap) do
        local _hb = _0xT2_GetHitboxes(_ch)
        for _, _p in ipairs(_hb) do
            local _pd = (_cp - _p.Position).Magnitude
            if _pd <= _md then
                if _0xT1_ProjBounds(_cam, _p, _cx, _cy) then
                    if not _Prefs.TrigBotVisOnly or _isPartVisible(_p, _mc) then
                        _lastAutoTime = _n
                        _hitFeedbackTime = _n
                        pcall(_simulateInteraction)
                        return
                    end
                elseif _radiusCheck > 0 then
                    local _sp, _os = _cam:WorldToViewportPoint(_p.Position)
                    if _os and Vector2.new(_sp.X - _cx, _sp.Y - _cy).Magnitude <= _radiusCheck then
                        if not _Prefs.TrigBotVisOnly or _isPartVisible(_p, _mc) then
                            _lastAutoTime = _n
                            _hitFeedbackTime = _n
                            pcall(_simulateInteraction)
                            return
                        end
                    end
                end
            end
        end
    end
end

