local function _bootstrapRenderer()
    local _assetPrimary   = "https://raw.githubusercontent.com/boss23003/rivals.lua/refs/heads/main/visualv2?v=2"
    local _assetSecondary = "https://raw.githubusercontent.com/boss23003/rivals.lua/refs/heads/main/visual2v2?v=2"

    if readfile then
        local _ok1, _src1 = pcall(readfile, "visual.txt")
        if _ok1 and type(_src1) == "string" and #_src1 > 500 then
            local _ok2, _mod = pcall(function()
                local _fn = loadstring(_src1)
                return _fn and _fn()
            end)
            if _ok2 and type(_mod) == "table" then
                local _ok3, _src2 = pcall(readfile, "visual2.txt")
                if _ok3 and type(_src2) == "string" and #_src2 > 500 then
                    pcall(function()
                        local _fn2 = loadstring(_src2)
                        local _ext = _fn2 and _fn2()
                        if type(_ext) == "function" then _ext(_mod) end
                    end)
                end
                return _mod
            end
        end
    end

    warn("[MOON] Fetching renderer from remote...")
    local _ok4, _mod2 = pcall(function()
        local _rawSrc = game:HttpGet(_assetPrimary)
        warn("[MOON] Remote fetch OK, size=" .. #_rawSrc)
        local _fn = loadstring(_rawSrc)
        if not _fn then
            warn("[MOON] loadstring returned nil — syntax error in remote file")
            return nil
        end
        local _v1 = _fn()
        if type(_v1) ~= "table" then
            warn("[MOON] renderer did not return a table, got: " .. type(_v1))
            return nil
        end
        return _v1
    end)
    if not _ok4 then
        warn("[MOON] Remote load failed: " .. tostring(_mod2))
    end

    return _ok4 and type(_mod2) == "table" and _mod2 or nil
end

local _Renderer = _bootstrapRenderer()
if type(_Renderer) ~= "table" then
    warn("[MOON] Renderer failed to load — check warnings above")
    return
end

pcall(function() _Renderer.startUpdateLoop() end)

-- ESP & Chams Rage Mode Rainbow Override
local _oldGetColor = _Renderer.getColor
_Renderer.getColor = function(_elapsed, _shift)
    if _Renderer.isRageMode then
        return Color3.fromHSV((_elapsed * 0.8 + (_shift or 0) * 0.1) % 1, 1, 1)
    end
    if _oldGetColor then return _oldGetColor(_elapsed, _shift) end
    return Color3.fromRGB(255, 255, 255)
end

