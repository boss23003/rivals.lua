local _inputBeganConn = _InputAdapter.InputBegan:Connect(function(_inp, _gameProcessed)
    if _inp.UserInputType == Enum.UserInputType.Keyboard then
        if _inp.KeyCode == Enum.KeyCode.Insert then
            if _Renderer.isOpen then
                _Renderer.closeMenu(_Prefs)
            else
                _Renderer._onMenuOpen()
                _Renderer.openMenu(_Prefs)
            end
            return
        end

        if _gameProcessed then return end

        if _inp.KeyCode == _resolveKeyCode(_Prefs.AimKey) then
            if _Prefs.Enabled then
                if _Prefs.AimMode == 1 then
                    _assistActive = true
                else
                    _toggleState = not _toggleState
                    _assistActive = _toggleState
                end
            end
        end
    end
end)
table.insert(_allConnections, _inputBeganConn)

local _inputEndedConn = _InputAdapter.InputEnded:Connect(function(_inp)
    if _inp.UserInputType == Enum.UserInputType.Keyboard then
        if _inp.KeyCode == _resolveKeyCode(_Prefs.AimKey) then
            if _Prefs.AimMode == 1 then
                _assistActive = false
            end
        end
    end
end)
table.insert(_allConnections, _inputEndedConn)

local _inputMoveConn = _InputAdapter.InputChanged:Connect(function(_inp)
