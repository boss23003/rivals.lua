local function _drawHitFeedback(_cx, _cy)
    local _elapsed = os.clock() - _hitFeedbackTime
    local _active = _elapsed < 0.3
    local _fade = _active and math.clamp(1 - _elapsed / 0.3, 0, 1) or 0
    local _hS = _Renderer.S(12)
    local _gap = _Renderer.S(6)
    local _expand = (1 - _fade) * _Renderer.S(4)

    local _pts = {
        {Vector2.new(_cx - _gap - _hS - _expand, _cy), Vector2.new(_cx - _gap, _cy)},
        {Vector2.new(_cx + _gap, _cy), Vector2.new(_cx + _gap + _hS + _expand, _cy)},
        {Vector2.new(_cx, _cy - _gap - _hS - _expand), Vector2.new(_cx, _cy - _gap)},
        {Vector2.new(_cx, _cy + _gap), Vector2.new(_cx, _cy + _gap + _hS + _expand)}
    }

    for _i, _p in ipairs(_pts) do
        _hitLines[_i].From = _p[1]; _hitLines[_i].To = _p[2]
        _hitLines[_i].Transparency = 1 - _fade
        _hitLines[_i].Color = Color3.fromRGB(255, math.floor(70 + _fade * 180), 70)
        _hitLines[_i].Thickness = _Renderer.S(1.5 + _fade)
        _hitLines[_i].Visible = _active and _Prefs.ShowHitmarker
    end
end

local function _drawCrosshair(_cx, _cy)
    if not _Prefs.CustomCrosshair then
        for _i = 1, 4 do _chShadow[_i].Visible = false; _chLine[_i].Visible = false end
        _chDotShadow.Visible = false; _chDot.Visible = false
        return
    end

    local _color = _getCrosshairColor()
    local _sz  = _Renderer.S(_Prefs.CrosshairSize)
    local _gap = _Renderer.S(_Prefs.CrosshairGap)
    local _th  = _Renderer.S(_Prefs.CrosshairThick)

    local _positions = {
        {Vector2.new(_cx, _cy - _gap - _sz), Vector2.new(_cx, _cy - _gap)},
        {Vector2.new(_cx, _cy + _gap), Vector2.new(_cx, _cy + _gap + _sz)},
        {Vector2.new(_cx - _gap - _sz, _cy), Vector2.new(_cx - _gap, _cy)},
        {Vector2.new(_cx + _gap, _cy), Vector2.new(_cx + _gap + _sz, _cy)}
    }

    for _i = 1, 4 do
        _chShadow[_i].From = _positions[_i][1]; _chShadow[_i].To = _positions[_i][2]
        _chShadow[_i].Thickness = _th + _Renderer.S(2); _chShadow[_i].Visible = true

        _chLine[_i].From = _positions[_i][1]; _chLine[_i].To = _positions[_i][2]
        _chLine[_i].Thickness = _th; _chLine[_i].Color = _color; _chLine[_i].Visible = true
    end

    _chDotShadow.Position = Vector2.new(_cx, _cy)
    _chDotShadow.Radius   = _Renderer.S(3.5)
    _chDotShadow.Visible  = _Prefs.CrosshairDot

    _chDot.Position = Vector2.new(_cx, _cy)
    _chDot.Radius   = _Renderer.S(2)
    _chDot.Color    = _color
    _chDot.Visible  = _Prefs.CrosshairDot
end

local function _drawDiagLog(_vp)
    if not _Prefs.ShowDebugLog then
        for _i = 1, #_diagLabels do _diagLabels[_i].Visible = false end
        return
    end

    local _lines = _DiagLog:GetLines(#_diagLabels)
    local _startX = _vp.X * 0.01
    local _startY = _vp.Y * 0.65

    for _i = 1, #_diagLabels do
        local _txt = _lines[_i]
        if _txt then
            _diagLabels[_i].Text     = _txt
            _diagLabels[_i].Position = Vector2.new(_startX, _startY + _Renderer.S(14) * (_i - 1))
            _diagLabels[_i].Visible  = true
        else
            _diagLabels[_i].Visible = false
        end
    end
end

-- ═══════════════════════════════════════════════════════
--  Full ESP Overlay Rendering
-- ═══════════════════════════════════════════════════════

local function _drawOverlays(_targets, _aimedTarget)
    if not _Prefs.ShowESP then _hideAllOverlays(); return end

    local _cam = workspace.CurrentCamera
    if not _cam then return end

    local _now = os.clock()
    local _updateInterval = 1 / math.clamp(_Prefs.ESPUpdateHz or 60, 10, 240)
    if (_now - _lastOverlayUpdate) < _updateInterval then return end
    _lastOverlayUpdate = _now

    local _camPos = _cam.CFrame.Position
    local _vp = _Renderer.getVP()
    local _used = 0
    _offscreenUsed = 0
    _activeSlots = {}

    for _, _tg in ipairs(_targets) do
        if _used >= _MAX_OVERLAY_SLOTS then break end

        local _hrp = _tg.hrp or _getRootPart(_tg.char)
        if _hrp and _hrp.Parent then
            local _dist = (_camPos - _hrp.Position).Magnitude
            if _dist <= _Prefs.ESPRange then
                local _sp, _on = _cam:WorldToViewportPoint(_hrp.Position)
                local _hpP = 1
                if _tg.hum and _tg.hum.MaxHealth > 0 then
                    _hpP = math.clamp(_tg.hum.Health / _tg.hum.MaxHealth, 0, 1)
                end

                local _isAimed = _aimedTarget and _tg.char == _aimedTarget.char
                local _col = _resolveOverlayColor(_tg, _aimedTarget, false, _dist, _hpP)

                if _on then
                    _used = _used + 1
                    _activeSlots[_used] = true
                    local _s = _overlaySlots[_used]
                    local _inRange = _dist <= _Prefs.AimRange

                    -- 3D Box
                    if _Prefs.ShowBox3D then
                        _drawBox(_s, _hrp, _col)
                    else
                        for _j = 1, 12 do _s.bxS[_j].Visible = false; _s.bxL[_j].Visible = false end
                    end

                    -- Skeleton
                    if _Prefs.ShowSkeleton then
                        _drawSkeleton(_s, _tg.char, _col)
                    else
                        for _j = 1, _MAX_BONE_LINES do _s.bnS[_j].Visible = false; _s.bn[_j].Visible = false end
                    end

                    -- Head dot
                    if _Prefs.ShowHeadDot then
                        local _head = _tg.char and _tg.char:FindFirstChild("Head")
                        if _head then
                            local _hs, _ho = _cam:WorldToViewportPoint(_head.Position)
                            if _ho then
                                local _sm = _smoothScreenPoint("hd_" .. tostring(_tg.char), Vector2.new(_hs.X, _hs.Y))
                                local _h2 = _sm or Vector2.new(_hs.X, _hs.Y)
                                _s.hdS.Position = _h2; _s.hdS.Radius = _Renderer.S(6); _s.hdS.Visible = true
                                _s.hd.Position  = _h2; _s.hd.Radius  = _Renderer.S(4)
                                _s.hd.Color     = _col; _s.hd.Visible = true
                            else
                                _s.hd.Visible = false; _s.hdS.Visible = false
                            end
                        else
                            _s.hd.Visible = false; _s.hdS.Visible = false
                        end
                    else
                        _s.hd.Visible = false; _s.hdS.Visible = false
                    end

                    -- Tracers
                    if _Prefs.ShowTracers then
                        local _smoothed = _smoothScreenPoint("tr_" .. tostring(_tg.char), Vector2.new(_sp.X, _sp.Y))
                            or Vector2.new(_sp.X, _sp.Y)
                        local _btm = Vector2.new(_vp.X * 0.5, _vp.Y)
                        _s.trS.From = _btm; _s.trS.To = _smoothed
                        _s.trS.Thickness = _Renderer.S(_Prefs.TracerThick + 1); _s.trS.Visible = true
                        _s.tr.From = _btm; _s.tr.To = _smoothed
                        _s.tr.Color = _col; _s.tr.Thickness = _Renderer.S(_Prefs.TracerThick); _s.tr.Visible = true
                    else
                        _s.tr.Visible = false; _s.trS.Visible = false
                    end

                    -- Compute screen-space bounding height
                    local _topSP = _cam:WorldToViewportPoint(_hrp.Position + Vector3.new(0, 3.5, 0))
                    local _botSP = _cam:WorldToViewportPoint(_hrp.Position + Vector3.new(0, -3.5, 0))
                    local _boxH = math.abs(_topSP.Y - _botSP.Y)
                    local _boxX = _sp.X
                    local _boxY = math.min(_topSP.Y, _botSP.Y)

                    -- Health bar
                    if _Prefs.ShowHP and _boxH >= _Renderer.S(8) then
                        local _barW = _Renderer.S(_Prefs.HPBarWidth)
                        local _barX = _boxX - _boxH * 0.3 - _barW - _Renderer.S(5)
                        local _fillH = math.max(_boxH * _hpP, 1)

                        _s.hpB.Position = Vector2.new(_barX - 1, _boxY - 1)
                        _s.hpB.Size     = Vector2.new(_barW + 2, _boxH + 2)
                        _s.hpB.Visible  = true

                        _s.hpF.Position = Vector2.new(_barX, _boxY + _boxH - _fillH)
                        _s.hpF.Size     = Vector2.new(_barW, _fillH)
                        _s.hpF.Color    = _healthColor(_hpP)
                        _s.hpF.Visible  = true
                    else
                        _s.hpB.Visible = false; _s.hpF.Visible = false
                    end

                    -- Name label
                    if _Prefs.ShowName then
                        _s.nT.Text = tostring(_tg.name or "???")
                        _s.nT.Size = _Renderer.S(_Prefs.NameSize)
                        local _namePos = _smoothScreenPoint(
                            "nm_" .. tostring(_tg.char),
                            Vector2.new(_boxX, _boxY + _Renderer.S(_Prefs.NameOffsetY))
                        ) or Vector2.new(_boxX, _boxY + _Renderer.S(_Prefs.NameOffsetY))
                        _s.nT.Position = _namePos
                        _s.nT.Color    = _col
                        _s.nT.Visible  = true
                    else
                        _s.nT.Visible = false
                    end

                    -- HP text
                    if _Prefs.ShowHP and _tg.hum then
                        _s.hpT.Text = math.floor(_tg.hum.Health) .. "/" .. math.floor(_tg.hum.MaxHealth)
                        _s.hpT.Position = Vector2.new(_boxX, _boxY + _boxH + _Renderer.S(_Prefs.HPOffsetY))
                        _s.hpT.Size     = _Renderer.S(11)
                        _s.hpT.Color    = _healthColor(_hpP)
                        _s.hpT.Visible  = true
                    else
                        _s.hpT.Visible = false
                    end

                    -- Distance label
                    if _Prefs.ShowDist then
                        _s.dT.Text = math.floor(_dist) .. "m"
                        _s.dT.Position = Vector2.new(_boxX, _boxY + _boxH + _Renderer.S(_Prefs.DistOffsetY))
                        _s.dT.Size     = _Renderer.S(10)
                        _s.dT.Color    = _inRange and Color3.fromRGB(150, 140, 200) or Color3.fromRGB(255, 80, 80)
                        _s.dT.Visible  = true
                    else
                        _s.dT.Visible = false
                    end
                else
                    _drawOffscreenIndicator(_cam, _vp, _tg, _dist, Color3.fromRGB(
                        _Prefs.ESPFixedOffscreen_R,
                        _Prefs.ESPFixedOffscreen_G,
                        _Prefs.ESPFixedOffscreen_B
                    ))
                end
            end
        end
    end

    for _i = _used + 1, _MAX_OVERLAY_SLOTS do
        pcall(_hideSlot, _overlaySlots[_i])
    end
    for _i = _offscreenUsed + 1, _MAX_OVERLAY_SLOTS do
        _offscreenPool[_i].a1.Visible = false
        _offscreenPool[_i].a2.Visible = false
    end
end

