local function _get3DCorners(_cf, _size)
    local _x, _y, _z = _size.X * 0.5, _size.Y * 0.5, _size.Z * 0.5
    return {
        _cf * CFrame.new(-_x, -_y, -_z), _cf * CFrame.new(_x, -_y, -_z),
        _cf * CFrame.new(_x, _y, -_z),   _cf * CFrame.new(-_x, _y, -_z),
        _cf * CFrame.new(-_x, -_y, _z),  _cf * CFrame.new(_x, -_y, _z),
        _cf * CFrame.new(_x, _y, _z),    _cf * CFrame.new(-_x, _y, _z)
    }
end

local function _drawBox(_slot, _hrp, _color)
    local _cam = workspace.CurrentCamera
    if not _cam or not _hrp or not _hrp.Parent then return end

    local _corners = _get3DCorners(_hrp.CFrame * CFrame.new(0, -0.5, 0), Vector3.new(4, 6, 2.5))
    local _screenPts = {}

    for _i = 1, 8 do
        local _sp, _on = _cam:WorldToViewportPoint(_corners[_i].Position)
        if not _on then
            for _j = 1, 12 do
                _slot.bxS[_j].Visible = false
                _slot.bxL[_j].Visible = false
            end
            return
        end
        _screenPts[_i] = Vector2.new(_sp.X, _sp.Y)
    end

    local _bThick = _Renderer.S(_Prefs.BoxThick)
    for _i = 1, 12 do
        local _edge = _BOX_EDGES[_i]
        _slot.bxS[_i].From = _screenPts[_edge[1]]
        _slot.bxS[_i].To   = _screenPts[_edge[2]]
        _slot.bxS[_i].Thickness = _bThick + _Renderer.S(1.2)
        _slot.bxS[_i].Visible = true

        _slot.bxL[_i].From  = _screenPts[_edge[1]]
        _slot.bxL[_i].To    = _screenPts[_edge[2]]
        _slot.bxL[_i].Color = _color
        _slot.bxL[_i].Thickness = _bThick
        _slot.bxL[_i].Visible = true
    end
end

