local function _drawSkeleton(_slot, _char, _color)
    local _cam = workspace.CurrentCamera
    if not _cam or not _char or not _char.Parent then return end

    local _rig = _getRigType(_char)
    if _rig == "?" then
        for _i = 1, _MAX_BONE_LINES do
            _slot.bn[_i].Visible  = false
            _slot.bnS[_i].Visible = false
        end
        return
    end

    local _boneList = _rig == "R15" and _BONES_R15 or _BONES_R6
    local _idx = 0

    for _, _pair in ipairs(_boneList) do
        local _a = _char:FindFirstChild(_pair[1])
        local _b = _char:FindFirstChild(_pair[2])

        if _a and _b and _a:IsA("BasePart") and _b:IsA("BasePart") then
            _idx = _idx + 1
            if _idx > _MAX_BONE_LINES then break end

            local _sA, _oA = _cam:WorldToViewportPoint(_a.Position)
            local _sB, _oB = _cam:WorldToViewportPoint(_b.Position)

            if _oA and _oB then
                local _pA = Vector2.new(_sA.X, _sA.Y)
                local _pB = Vector2.new(_sB.X, _sB.Y)

                _slot.bnS[_idx].From = _pA; _slot.bnS[_idx].To = _pB
                _slot.bnS[_idx].Thickness = _Renderer.S(2.2)
                _slot.bnS[_idx].Visible = true

                _slot.bn[_idx].From  = _pA; _slot.bn[_idx].To = _pB
                _slot.bn[_idx].Color = _color
                _slot.bn[_idx].Visible = true
            else
                _slot.bnS[_idx].Visible = false
                _slot.bn[_idx].Visible  = false
            end
        end
    end

    for _i = _idx + 1, _MAX_BONE_LINES do
        _slot.bnS[_i].Visible = false
        _slot.bn[_i].Visible  = false
    end
end

