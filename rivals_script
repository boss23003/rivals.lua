local function _resolveOverlayColor(_tg, _aimedTarget, _unused, _dist, _hpPercent)
    if _Renderer.isRageMode then
        local hue = (os.clock() * 1.5 + (_dist * 0.005)) % 1
        return Color3.fromHSV(hue, 1, 1)
    end
    local _mode = _Prefs.ESPColorMode or 1

    if _mode == 1 then
        if _aimedTarget and _aimedTarget.char == _tg.char then
            return Color3.fromRGB(255, 235, 80)
        end
        return _Renderer.getColor(os.clock(), 0)

    elseif _mode == 2 then
        if _aimedTarget and _aimedTarget.char == _tg.char then
            return Color3.fromRGB(_Prefs.ESPFixedAim_R, _Prefs.ESPFixedAim_G, _Prefs.ESPFixedAim_B)
        end
        return Color3.fromRGB(_Prefs.ESPFixedEnemy_R, _Prefs.ESPFixedEnemy_G, _Prefs.ESPFixedEnemy_B)

    else
        local _dNorm = math.clamp(_dist / math.max(_Prefs.ESPRange, 1), 0, 1)
        local _hNorm = _hpPercent
        local _r = 255
        local _g = math.floor(60 + (1 - _dNorm) * 150)
        local _b = math.floor(80 + _hNorm * 120)

        if _aimedTarget and _aimedTarget.char == _tg.char then
            _r = 255; _g = 235; _b = 80
        end

        return Color3.fromRGB(_r, _g, _b)
    end
end

local function _smoothScreenPoint(_id, _pos2d)
    if not _pos2d then return nil end

    local _now = os.clock()
    local _cache = _smoothCache[_id]

    if not _cache then
        _smoothCache[_id] = {pos = _pos2d, t = _now}
        return _pos2d
    end

    local _dt = math.max(_now - _cache.t, 0.0001)
    local _maxJump = _Prefs.ESPMaxTeleport or 80
    local _lerpAlpha = math.clamp((_Prefs.ESPLineSmooth or 0.35) * _dt * 60, 0.05, 1)
    local _from = _cache.pos

    local _dx = _pos2d.X - _from.X
    local _dy = _pos2d.Y - _from.Y

    if math.abs(_dx) > _maxJump or math.abs(_dy) > _maxJump then
        _cache.pos = _pos2d
        _cache.t   = _now
        return _pos2d
    end

    local _newPos = Vector2.new(
        _from.X + _dx * _lerpAlpha,
        _from.Y + _dy * _lerpAlpha
    )
    _cache.pos = _newPos
    _cache.t   = _now
    return _newPos
end

-- ═══════════════════════════════════════════════════════
--  Offscreen Indicator
-- ═══════════════════════════════════════════════════════

local function _drawOffscreenIndicator(_cam, _vp, _tg, _dist, _color)
    if not _Prefs.ShowOffscreen then return end
    if not _tg.hrp or not _tg.hrp.Parent then return end

    local _sp, _on = _cam:WorldToViewportPoint(_tg.hrp.Position)
    if _on then return end

    _offscreenUsed = _offscreenUsed + 1
    if _offscreenUsed > _MAX_OVERLAY_SLOTS then return end

    local _slot = _offscreenPool[_offscreenUsed]
    local _center = Vector2.new(_vp.X * 0.5, _vp.Y * 0.5)
    local _dir = Vector2.new(_sp.X - _center.X, _sp.Y - _center.Y)
    if _dir.Magnitude < 1 then return end
    _dir = _dir.Unit

    local _margin = _Renderer.S(40)
    local _bx = _vp.X * 0.5 - _margin
    local _by = _vp.Y * 0.5 - _margin
    local _kx = math.abs(_dir.X) > 0.001 and math.abs(_bx / _dir.X) or 9999
    local _ky = math.abs(_dir.Y) > 0.001 and math.abs(_by / _dir.Y) or 9999
    local _k = math.min(_kx, _ky)
    local _edgePos = _center + _dir * _k
    local _ang = math.atan2(_dir.Y, _dir.X)
    local _arrowSize = _Renderer.S(10)

    local _id = "off_" .. (_tg.name or tostring(_tg.hrp))
    local _smoothed = _smoothScreenPoint(_id, _edgePos)

    local _p1 = _smoothed + Vector2.new(-math.cos(_ang) * _arrowSize, -math.sin(_ang) * _arrowSize)
    local _p2 = _smoothed + Vector2.new(math.cos(_ang + 2.5) * _arrowSize, math.sin(_ang + 2.5) * _arrowSize)
    local _p3 = _smoothed + Vector2.new(math.cos(_ang - 2.5) * _arrowSize, math.sin(_ang - 2.5) * _arrowSize)

    _slot.a1.From = _p1; _slot.a1.To = _p2
    _slot.a1.Color = _color; _slot.a1.Visible = true

    _slot.a2.From = _p1; _slot.a2.To = _p3
    _slot.a2.Color = _color; _slot.a2.Visible = true
end

