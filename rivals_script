-- ═══════════════════════════════════════════════════════
--  Main Heartbeat Loop
--  (Removed: orbit, spin, dash logic)
-- ═══════════════════════════════════════════════════════

local _fpsCounter, _fpsAccum = 0, 0
local _cleanupTimer = 0

local _mainLoopConn = _HeartbeatSignal:Connect(function(_dt)
    _globalClock = os.clock()

    -- FPS measurement
    _fpsAccum = _fpsAccum + _dt
    _fpsCounter = _fpsCounter + 1
    if _fpsAccum >= 1 then
        _currentFPS = _fpsCounter
        _fpsCounter = 0
        _fpsAccum = 0
    end

    -- Periodic cleanup
    _cleanupTimer = _cleanupTimer + 1
    if _cleanupTimer >= _currentFPS * 5 then
        _cleanupTimer = 0
        _cleanupMotionHistory()
        _cleanupOverlaySlots()
        _LifecycleTracker:Cleanup()
    end

    -- Auto performance optimization
    if _Prefs.AutoOptimize and _currentFPS > 0 and _currentFPS < (_Prefs.LowFPSThreshold or 35) then
        if _Prefs.SafeDisableESPDetails then
            _Prefs.ShowSkeleton = false
            _Prefs.ShowTracers  = false
            _Prefs.ShowHeadDot  = true
        end
        if _Prefs.SafeDisableChams then _Prefs.ShowChams = false end
    end

    -- Keep mouse unlocked while menu is open
    if _Renderer.isOpen then
        _InputAdapter.MouseBehavior    = Enum.MouseBehavior.Default
        _InputAdapter.MouseIconEnabled = true
    end

    -- Session analytics
    _updateSessionKills()

    -- Enumerate targets (single pass)
    local _targets = _enumerateTargets()
    _currentAimTarget = nil

    -- Bunny hop system
    _updateBhop(_dt)

    -- [REMOVED FORCETHIRDPERSON]

    -- Camera assist (aim)
    if _Prefs.Enabled and _assistActive and not _Renderer.isOpen then
        _currentAimTarget = _findClosestTarget(_targets, _dt)
        if _currentAimTarget then
            local _aimPos = _getPredictedPosition(_currentAimTarget, _dt)
            if _aimPos then
                _applyCameraAssist(_aimPos, _dt)
            end
        end
    end

    -- Auto-interaction (improved hitbox triggerbot)
    if not _Renderer.isOpen then
        _runAutoInteraction(_targets)
    end

    -- Highlight system (chams)
    _Renderer.updateChams(_targets, _Prefs)

    -- ── Drawing Updates ──
    local _cam = workspace.CurrentCamera
    local _cx, _cy = _Renderer.getCenter()

    -- FOV guide circles
    if _Prefs.ShowFOV and _Prefs.Enabled and not _Renderer.isOpen then
        local _col1 = _Renderer.getColor(_globalClock, 0)
        local _col2 = _Renderer.getColor(_globalClock, 1)
        local _alpha = _Renderer.UIConfigs.UITransparency or 0.15

        _fovRing1.Position     = Vector2.new(_cx, _cy)
        _fovRing1.Radius       = _Prefs.FOV
        _fovRing1.Color        = _col1
        _fovRing1.Transparency = math.clamp(0.45 - _alpha, 0.1, 1)
        _fovRing1.Visible      = true

        _fovRing2.Position     = Vector2.new(_cx, _cy)
        _fovRing2.Radius       = _Prefs.FOV + 3
        _fovRing2.Color        = _col2
        _fovRing2.Transparency = math.clamp(0.75 - _alpha, 0.1, 1)
        _fovRing2.Visible      = true

        _fovRing3.Position     = Vector2.new(_cx, _cy)
        _fovRing3.Radius       = _Prefs.FOV + 6
        _fovRing3.Color        = _col2
        _fovRing3.Transparency = math.clamp(0.9 - _alpha, 0.1, 1)
        _fovRing3.Visible      = true
    else
        _fovRing1.Visible = false
        _fovRing2.Visible = false
        _fovRing3.Visible = false
    end

    -- Snap line to aimed target
    if _Prefs.ShowSnapLine and _currentAimTarget and _currentAimTarget.part and _cam and not _Renderer.isOpen then
        local _sp, _on = _cam:WorldToViewportPoint(_currentAimTarget.part.Position)
        if _on then
            local _pt = Vector2.new(_sp.X, _sp.Y)
            local _ct = Vector2.new(_cx, _cy)
            _snapShadow.From = _ct; _snapShadow.To = _pt; _snapShadow.Visible = true
            _snapLine.From = _ct; _snapLine.To = _pt
            _snapLine.Color = _Renderer.getAuroraColor(_globalClock, 0.5)
            _snapLine.Visible = true
        else
            _snapShadow.Visible = false; _snapLine.Visible = false
        end
    else
        _snapShadow.Visible = false; _snapLine.Visible = false
    end

    -- Aim indicator dot/ring
    if _currentAimTarget and _currentAimTarget.part and _cam and not _Renderer.isOpen then
        local _sp, _on = _cam:WorldToViewportPoint(_currentAimTarget.part.Position)
        if _on then
            local _pt = Vector2.new(_sp.X, _sp.Y)
            _aimDot.Position = _pt; _aimDot.Visible = true
            _aimRing.Position = _pt
            _aimRing.Color = _Renderer.getAuroraColor(_globalClock, 0.8)
            _aimRing.Visible = true
        else
            _aimDot.Visible = false; _aimRing.Visible = false
        end
    else
        _aimDot.Visible = false; _aimRing.Visible = false
    end

    -- Hit feedback, crosshair
    _drawHitFeedback(_cx, _cy)
    _drawCrosshair(_cx, _cy)

    -- ESP overlay (throttled)
    _overlayUpdateCounter = _overlayUpdateCounter + 1
    if _overlayUpdateCounter >= (_currentFPS < 45 and 2 or 1) then
        _overlayUpdateCounter = 0
        _drawOverlays(_targets, _currentAimTarget)
    end

    -- ── GUI Status Updates ──
    pcall(function()
        _Renderer.guiStatus.Text = _Prefs.Enabled and (_assistActive and "AIM" or "ON") or "OFF"
        _Renderer.guiFPS.Text    = tostring(_currentFPS) .. " fps"
        _Renderer.guiKills.Text  = _sessionKills .. " kills"
    end)

    pcall(function()
        local _ping = math.floor(_PerfMonitor.Network.ServerStatsItem["Data Ping"]:GetValue())
        _Renderer.guiPing.Text = _ping .. "ms"
    end)

    -- Target info labels
    pcall(function()
        if _currentAimTarget then
            _guiTargetName.Text = "→ " .. tostring(_currentAimTarget.name)
            local _hp    = _currentAimTarget.hum and math.floor(_currentAimTarget.hum.Health) or 0
            local _maxHP = _currentAimTarget.hum and math.floor(_currentAimTarget.hum.MaxHealth) or 0
            local _dist  = _currentAimTarget.part and _cam and math.floor((_cam.CFrame.Position - _currentAimTarget.part.Position).Magnitude) or 0
            _guiTargetHP.Text = _hp .. "/" .. _maxHP .. "  " .. _dist .. "m"
        else
            _guiTargetName.Text = _Prefs.Enabled and "scanning..." or "off"
            _guiTargetHP.Text = ""
        end
    end)

    -- HUD telemetry
    if _Prefs.ShowHUD then
        _Renderer.hudFrame.Visible = true
        local _lines = {}
        _lines[#_lines + 1] = "MOON v4.2"
        _lines[#_lines + 1] = "FPS: " .. _currentFPS
        pcall(function()
            _lines[#_lines + 1] = "Ping: " .. math.floor(_PerfMonitor.Network.ServerStatsItem["Data Ping"]:GetValue()) .. "ms"
        end)
        _lines[#_lines + 1] = "Aim: "    .. (_Prefs.Enabled and (_assistActive and "LOCK" or "ON") or "OFF")
        _lines[#_lines + 1] = "ESP: "    .. (_Prefs.ShowESP and "ON" or "OFF")
        _lines[#_lines + 1] = "Chams: "  .. (_Prefs.ShowChams and "ON" or "OFF")
        _lines[#_lines + 1] = "Kills: "  .. _sessionKills
        if _Prefs.BhopEnabled then _lines[#_lines + 1] = "Bhop: ON" end
        if _Prefs.Triggerbot then _lines[#_lines + 1] = "TrigBot: ON" end
        if _currentAimTarget then _lines[#_lines + 1] = "Aim: " .. tostring(_currentAimTarget.name) end
        if _Prefs.AutoOptimize then
            _lines[#_lines + 1] = "AutoOpt: " .. (_currentFPS < (_Prefs.LowFPSThreshold or 35) and "ACTIVE" or "OK")
        end

        for _i = 1, _Renderer.HUD_MAX do
            if _i <= #_lines then
                _Renderer.hudT[_i].Text    = _lines[_i]
                _Renderer.hudT[_i].Visible = true
            else
                _Renderer.hudT[_i].Visible = false
            end
        end
    else
        _Renderer.hudFrame.Visible = false
    end

    -- Active binds display
    _Renderer.updateActiveBinds(_Prefs, _Palette, _assistActive, false, false, false)

    -- Debug log overlay
    _drawDiagLog(_Renderer.getVP())
end)
table.insert(_allConnections, _mainLoopConn)

