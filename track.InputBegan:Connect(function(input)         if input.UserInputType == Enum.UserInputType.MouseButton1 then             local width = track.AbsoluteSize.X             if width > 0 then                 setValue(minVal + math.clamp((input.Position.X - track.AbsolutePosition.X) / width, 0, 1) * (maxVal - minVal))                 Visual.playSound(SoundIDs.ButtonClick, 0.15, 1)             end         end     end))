    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.ZIndex = 22
    btn.AutoButtonColor = false
    btn.Parent = row
    btn.MouseButton1Click:Connect(function()
        Visual.PlaySound("Click", 0.2, 1.0)
        Visual.Ripple(row, row.AbsoluteSize.X / 2, row.AbsoluteSize.Y / 2)
        valLabel.Text = "..."
        rebinding = true
        local cn
        cn = UserInputService.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Keyboard then
                local n = inp.KeyCode.Name
                if n ~= "Unknown" then
                    CFG[cfgKey] = n
                    valLabel.Text = "[ " .. n .. " ]"
                    rebinding = false
                    pcall(function() cn:Disconnect() end)
                    Visual.PlaySound("ToggleOn", 0.2, 1.3)
                end
            end
        end)
        task.delay(5, function()
            if rebinding then
                rebinding = false
                valLabel.Text = "[ " .. CFG[cfgKey] .. " ]"
                pcall(function() cn:Disconnect() end)
            end
        end)
    end)
