    Instance.new("UICorner", barFill).CornerRadius = UDim.new(1, 0)
    local barFillGrad = Instance.new("UIGradient")
    barFillGrad.Color = Visual.getAuroraSequence(os.clock())
    barFillGrad.Parent = barFill

