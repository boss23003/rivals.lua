        local mx2 = UserInputService:GetMouseLocation()
        Visual.Ripple(row, mx2.X - row.AbsolutePosition.X, mx2.Y - row.AbsolutePosition.Y)
        idx = idx % #opts + 1
        CFG[key] = idx
        valLabel.Text = tostring(opts[idx])
        if callback then callback(idx) end
    end)
