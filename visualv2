function _LayoutEngine.updateActiveBinds(_cfg, _ctx, _assistActive, _lockActive, _rotActive, _enhancedMode)
    local _stateMap = {
        {"Aimbot",   _cfg.Enabled,      "aim " .. (_cfg.Enabled and "on" or "off") .. " (" .. tostring(_cfg.AimKey or "?") .. ")"},
        {"Locking",  _assistActive,      "aim lock (" .. tostring(_cfg.AimKey or "?") .. ")"},
        {"Target",   _lockActive,        "target on (" .. tostring(_cfg.TargetKey or "?") .. ")"},
        {"Spin",     _rotActive,         "spin on"},
        {"Triggerbot", _cfg.Triggerbot,   "trigger on"},
        {"ESP",      _cfg.ShowESP,       "esp on"},
        {"Chams",    _cfg.ShowChams,     "chams on"},
        {"Dash",     _cfg.DashEnabled,   "dash ready (" .. tostring(_cfg.DashKey or "?") .. ")"},
        {"Rage",     _enhancedMode,      _enhancedMode and "rage mode enabled" or "rage mode disabled"},
        {"R.Dash",   _cfg.RageDash,      "rage dash on"},
        {"R.Target", _cfg.RageTarget,    "rage target on"}
    }

    for _, _item in ipairs(_stateMap) do
        local _ck, _cur = _item[1], _item[2]
        if _LayoutEngine._bindsStateCache[_ck] == nil then
            _LayoutEngine._bindsStateCache[_ck] = _cur
        elseif _LayoutEngine._bindsStateCache[_ck] ~= _cur then
            _LayoutEngine._bindsStateCache[_ck] = _cur
            if _cur then
                _LayoutEngine.pushBindEvent(_item[3])
            end
        end
    end

    -- Clear previous static rows
    for _, _child in ipairs(_kpContent:GetChildren()) do
        if _child:IsA("Frame") and _child.Name == "BindStateRow" then
            _child:Destroy()
        end
    end

    -- Build current active bind list
    local _activeItems = {}
    local function _addItem(_n, _a, _k)
        _activeItems[#_activeItems + 1] = {n = _n, a = _a, k = _k or ""}
    end

    _addItem("Aimbot",  _cfg.Enabled,    _cfg.AimKey)
    if _assistActive then _addItem("Locking", true, _cfg.AimKey) end
    if _lockActive   then _addItem("Target",  true, _cfg.TargetKey) end
    if _rotActive    then _addItem("Spin",    true, "") end
    _addItem("Trigger", _cfg.Triggerbot, "")
    _addItem("ESP",     _cfg.ShowESP,    "")
    _addItem("Chams",   _cfg.ShowChams,  "")
    _addItem("Dash",    _cfg.DashEnabled, _cfg.DashKey)
    if _enhancedMode   then _addItem("Rage",     true, "") end
    if _cfg.RageDash   then _addItem("R.Dash",   true, "") end
    if _cfg.RageTarget then _addItem("R.Target", true, "") end

    -- Render rows
    for _idx, _item in ipairs(_activeItems) do
        local _row = Instance.new("Frame")
        _row.Name                   = "BindStateRow"
        _row.Size                   = UDim2.new(1, 0, 0, 18)
        _row.BackgroundColor3       = Color3.new(1, 1, 1)
        _row.BackgroundTransparency = 0.22
        _row.BorderSizePixel        = 0
        _row.ZIndex                 = 102
        _row.LayoutOrder            = 1000 + _idx
        _row.Parent                 = _kpContent

        Instance.new("UICorner", _row).CornerRadius = UDim.new(0, 7)

        local _rGrad = Instance.new("UIGradient")
        _rGrad.Color    = _LayoutEngine.getAuroraSequence(os.clock() + _idx)
        _rGrad.Rotation = 25
        _rGrad.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.3),
            NumberSequenceKeypoint.new(1, 0.12)
        })
        _rGrad.Parent = _row

        local _rLabel = Instance.new("TextLabel")
        _rLabel.Size                  = UDim2.new(1, -10, 1, 0)
        _rLabel.Position              = UDim2.new(0, 8, 0, 0)
        _rLabel.BackgroundTransparency = 1
        _rLabel.Text                  = _item.k ~= "" and (_item.n .. " (" .. _item.k .. ")") or _item.n
        _rLabel.TextColor3            = Color3.new(1, 1, 1)
        _rLabel.TextSize              = 9
        _rLabel.Font                  = Enum.Font.GothamBold
        _rLabel.TextXAlignment        = Enum.TextXAlignment.Left
        _rLabel.ZIndex                = 103
        _rLabel.Parent                = _row

        local _rlGrad = Instance.new("UIGradient")
        _rlGrad.Color  = _LayoutEngine.getAuroraSequence(os.clock() + _idx * 0.2)
        _rlGrad.Parent = _rLabel
    end

    -- Auto-resize panel to fit content
    _keybindPanel.Size = UDim2.new(
        0, 188,
        0, math.min(math.max(28 + #_activeItems * 21, 28) + 8, 240)
    )
end

