local function refreshTabButtons()
    for _, b in ipairs(tabButtons) do if b then b:Destroy() end end; table.clear(tabButtons)
    currentTabs = isRageMode and Visual.RageTabs or Visual.NormalTabs; Visual.TabNames = currentTabs
