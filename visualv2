-- SAFE OPERATION WRAPPERS (35 lines)
-- ═══════════════════════════════════════════════════════════════

function Visual.SafePcall(context, func, ...)
    Visual.Performance:Start(context)
    local success, result = pcall(func, ...)
    Visual.Performance:Stop(context)
    
    if not success then
        Visual.ErrorSystem:Log(context, result, "ERROR")
    end
    
    return success, result
end

function Visual.SafeTween(object, tweenInfo, properties, onComplete)
    if not object or not object.Parent then
        return nil
    end
    
    local tween = TweenService:Create(object, tweenInfo, properties)
    Visual.Memory:Track(tween, "Tween")
    
    tween.Completed:Connect(function()
        Visual.Memory:Untrack(tween)
        if onComplete then
            pcall(onComplete)
        end
        tween:Destroy()
    end)
    
    tween:Play()
    return tween
end

function Visual.SafeDestroy(object, delay)
    if not object then return end
    
    if delay and delay > 0 then
        Visual.Memory:QueueCleanup(object, delay)
    else
        pcall(function()
            if object.Parent then
                object:Destroy()
            end
        end)
    end
end

