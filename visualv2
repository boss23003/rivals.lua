        rg2.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0.3),NumberSequenceKeypoint.new(1,0.12)}); rg2.Parent = row
        local lb2 = Instance.new("TextLabel"); lb2.Size = UDim2.new(1,-10,1,0); lb2.Position = UDim2.new(0,8,0,0)
        lb2.BackgroundTransparency = 1; lb2.Text = item.k ~= "" and (item.n.." ("..item.k..")") or item.n
        lb2.TextColor3 = Color3.new(1,1,1); lb2.TextSize = 9; lb2.Font = Enum.Font.GothamBold
        lb2.TextXAlignment = Enum.TextXAlignment.Left; lb2.ZIndex = 103; lb2.Parent = row
        local lg3 = Instance.new("UIGradient"); lg3.Color = Visual.getAuroraSequence(os.clock()+index*0.2); lg3.Parent = lb2
