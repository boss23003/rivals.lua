    allConnections = allConnections or {}
    Visual._allConnections = allConnections

    Visual.createFOVCircle()
    Visual.buildUITab(CFG, allConnections)
    Visual.buildPatchTab()
    Visual.startUpdateLoop()
    Visual.showLoadingScreen()

    task.delay(2.5, function()
        Visual.Notify("MOON", "v3.5 loaded successfully", 4)
    end)
end

