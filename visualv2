function Visual.ConfigSystem.Export(CFG)
    local data = {}
    for _, key in ipairs(CONFIG_KEYS) do
        if CFG[key] ~= nil then data[key] = CFG[key] end
    end
    data._UI = {}
    for _, key in ipairs(UI_CONFIG_KEYS) do
        data._UI[key] = Visual.UIConfigs[key]
    end
    if Visual.UIConfigs.CustomColors then
        data._UI._CustomColors = {}
        for i, col in ipairs(Visual.UIConfigs.CustomColors) do
            data._UI._CustomColors[i] = {
                math.floor(col.R * 255),
                math.floor(col.G * 255),
                math.floor(col.B * 255)
            }
        end
    end
    local jsonStr = HttpService:JSONEncode(data)
    local encoded = nil
    pcall(function()
        local b64 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
        encoded = ""
        local bytes = {string.byte(jsonStr, 1, #jsonStr)}
        local i = 1
        while i <= #bytes do
            local b1 = bytes[i] or 0
            local b2 = bytes[i + 1] or 0
            local b3 = bytes[i + 2] or 0
            local n = b1 * 65536 + b2 * 256 + b3
            local c1 = math.floor(n / 262144) % 64
            local c2 = math.floor(n / 4096) % 64
            local c3 = math.floor(n / 64) % 64
            local c4 = n % 64
            encoded = encoded
                .. string.sub(b64, c1 + 1, c1 + 1)
                .. string.sub(b64, c2 + 1, c2 + 1)
                .. (i + 1 <= #bytes and string.sub(b64, c3 + 1, c3 + 1) or "=")
                .. (i + 2 <= #bytes and string.sub(b64, c4 + 1, c4 + 1) or "=")
            i = i + 3
        end
    end)
    if encoded then return "CFG-MOON-" .. encoded end
    return nil
end

function Visual.ConfigSystem.Import(cfgString, CFG)
    if not cfgString or type(cfgString) ~= "string" then return false end
    local encoded = cfgString
    if encoded:sub(1, 9) == "CFG-MOON-" then encoded = encoded:sub(10) end
    local decoded = nil
    pcall(function()
        local b64 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
        local result = {}
        local i = 1
        while i <= #encoded do
            local c1 = string.find(b64, encoded:sub(i, i), 1, true) or 1
            local c2 = string.find(b64, encoded:sub(i + 1, i + 1), 1, true) or 1
            local c3 = string.find(b64, encoded:sub(i + 2, i + 2), 1, true)
            local c4 = string.find(b64, encoded:sub(i + 3, i + 3), 1, true)
            c1 = c1 - 1; c2 = c2 - 1
            c3 = c3 and (c3 - 1) or 0
            c4 = c4 and (c4 - 1) or 0
            local n = c1 * 262144 + c2 * 4096 + c3 * 64 + c4
            table.insert(result, math.floor(n / 65536) % 256)
            if encoded:sub(i + 2, i + 2) ~= "=" then
                table.insert(result, math.floor(n / 256) % 256)
            end
            if encoded:sub(i + 3, i + 3) ~= "=" then
                table.insert(result, n % 256)
            end
            i = i + 4
        end
        decoded = string.char(unpack(result))
    end)
    if not decoded then return false end
    local ok, data = pcall(function() return HttpService:JSONDecode(decoded) end)
    if not ok or type(data) ~= "table" then return false end
    for _, key in ipairs(CONFIG_KEYS) do
        if data[key] ~= nil then CFG[key] = data[key] end
    end
    if data._UI then
        for _, key in ipairs(UI_CONFIG_KEYS) do
            if data._UI[key] ~= nil then Visual.UIConfigs[key] = data._UI[key] end
        end
        if data._UI._CustomColors then
            Visual.UIConfigs.CustomColors = {}
            for i, rgb in ipairs(data._UI._CustomColors) do
                Visual.UIConfigs.CustomColors[i] = Color3.fromRGB(rgb[1], rgb[2], rgb[3])
            end
        end
    end
    return true
end

function Visual.ConfigSystem.SaveToFile(CFG, name)
    name = name or "moon_config"
    local str = Visual.ConfigSystem.Export(CFG)
    if not str then return false end
    pcall(function()
        if writefile then writefile(name .. ".mooncfg", str) end
    end)
    return str
end

function Visual.ConfigSystem.LoadFromFile(CFG, name)
    name = name or "moon_config"
    local str = nil
    pcall(function()
        if readfile and isfile and isfile(name .. ".mooncfg") then
            str = readfile(name .. ".mooncfg")
        end
    end)
    if str then return Visual.ConfigSystem.Import(str, CFG) end
    return false
end

