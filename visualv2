    _row.MouseEnter:Connect(function()
        _AnimationService:Create(_row, TweenInfo.new(0.15), {BackgroundTransparency = 0.3}):Play()
    end)
    _row.MouseLeave:Connect(function()
        _AnimationService:Create(_row, TweenInfo.new(0.15), {BackgroundTransparency = 0.85}):Play()
    end)

    -- Label
    local _lbl = Instance.new("TextLabel")
    _lbl.Text                  = _text
    _lbl.Size                  = UDim2.new(0.55, 0, 0, 14)
    _lbl.BackgroundTransparency = 1
    _lbl.TextColor3            = Color3.new(1, 1, 1)
    _lbl.TextSize              = 10
    _lbl.Font                  = Enum.Font.Gotham
    _lbl.TextXAlignment        = Enum.TextXAlignment.Left
    _lbl.ZIndex                = 20
    _lbl.Parent                = _row

    local _lStroke = Instance.new("UIStroke")
    _lStroke.Thickness    = 1.2
    _lStroke.Color        = Color3.new(0, 0, 0)
    _lStroke.Transparency = 0.15
    _lStroke.Parent       = _lbl

    local _lGrad = Instance.new("UIGradient")
    _lGrad.Color = _LayoutEngine.getSequence(os.clock())
    _lGrad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.1),
        NumberSequenceKeypoint.new(1, 0.35)
    })
    _lGrad.Parent = _lbl

    -- Value display
    local _valLabel = Instance.new("TextLabel")
    _valLabel.Text = _step < 1 and string.format("%.2f", _cfg[_key]) or tostring(math.floor(_cfg[_key]))
    _valLabel.Size                  = UDim2.new(0.43, 0, 0, 14)
    _valLabel.Position              = UDim2.new(0.55, 0, 0, 0)
    _valLabel.BackgroundTransparency = 1
    _valLabel.TextColor3            = Color3.new(1, 1, 1)
    _valLabel.TextSize              = 11
    _valLabel.Font                  = Enum.Font.GothamBold
    _valLabel.TextXAlignment        = Enum.TextXAlignment.Right
    _valLabel.ZIndex                = 20
    _valLabel.Parent                = _row

    local _vStroke = Instance.new("UIStroke")
    _vStroke.Thickness    = 1.2
    _vStroke.Color        = Color3.new(0, 0, 0)
    _vStroke.Transparency = 0.15
    _vStroke.Parent       = _valLabel

    local _vGrad = Instance.new("UIGradient")
    _vGrad.Color  = _LayoutEngine.getSequence(os.clock())
    _vGrad.Parent = _valLabel

    -- Track
    local _track = Instance.new("Frame")
    _track.Size                  = UDim2.new(1, 0, 0, 6)
    _track.Position              = UDim2.new(0, 0, 0, 24)
    _track.BackgroundColor3      = Color3.new(1, 1, 1)
    _track.BackgroundTransparency = 0.7
    _track.BorderSizePixel       = 0
    _track.ZIndex                = 20
    _track.Parent                = _row

    Instance.new("UICorner", _track).CornerRadius = UDim.new(0, 3)

    local _trGrad = Instance.new("UIGradient")
    _trGrad.Color = _LayoutEngine.getSequence(os.clock())
    _trGrad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.5),
        NumberSequenceKeypoint.new(1, 0.3)
    })
    _trGrad.Parent = _track

    -- Fill
    local _pct = math.clamp((_cfg[_key] - _mn) / (_mx - _mn), 0, 1)

    local _fill = Instance.new("Frame")
    _fill.Size             = UDim2.new(_pct, 0, 1, 0)
    _fill.BackgroundColor3 = Color3.new(1, 1, 1)
    _fill.BorderSizePixel  = 0
    _fill.ZIndex           = 21
    _fill.Parent           = _track

    Instance.new("UICorner", _fill).CornerRadius = UDim.new(0, 3)

    local _fGrad = Instance.new("UIGradient")
    _fGrad.Color = _LayoutEngine.getSequence(os.clock())
    _fGrad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.15),
        NumberSequenceKeypoint.new(1, 0.02)
    })
    _fGrad.Parent = _fill

    -- Draggable knob
    local _knob = Instance.new("TextButton")
    _knob.Size             = UDim2.new(0, 16, 0, 16)
    _knob.AnchorPoint      = Vector2.new(0.5, 0.5)
    _knob.Position         = UDim2.new(_pct, 0, 0.5, 0)
    _knob.BackgroundColor3 = Color3.new(1, 1, 1)
    _knob.Text             = ""
    _knob.AutoButtonColor  = false
    _knob.BorderSizePixel  = 0
    _knob.ZIndex           = 23
    _knob.Parent           = _track

    Instance.new("UICorner", _knob).CornerRadius = UDim.new(1, 0)

    local _kGrad = Instance.new("UIGradient")
    _kGrad.Color  = _LayoutEngine.getSequence(os.clock())
    _kGrad.Parent = _knob

    local _kStroke = Instance.new("UIStroke")
    _kStroke.Thickness    = 1.5
    _kStroke.Color        = Color3.fromRGB(6, 3, 12)
    _kStroke.Transparency = 0.3
    _kStroke.Parent       = _knob

    table.insert(_LayoutEngine.themeCallbacks, function()
        pcall(function()
            _lGrad.Color = _LayoutEngine.getSequence(os.clock())
            _vGrad.Color = _LayoutEngine.getSequence(os.clock() + 0.5)
            _fGrad.Color = _LayoutEngine.getSequence(os.clock())
            _kGrad.Color = _LayoutEngine.getSequence(os.clock())
        end)
    end)

    local _dragging = false

    local function _setValue(_val)
        if _step > 0 then
            _val = math.floor(_val / _step + 0.5) * _step
        end
        _val = math.clamp(_val, _mn, _mx)
        _cfg[_key] = _val

        local _p = math.clamp((_val - _mn) / (_mx - _mn), 0, 1)
        _fill.Size    = UDim2.new(_p, 0, 1, 0)
        _knob.Position = UDim2.new(_p, 0, 0.5, 0)
        _valLabel.Text = _step < 1 and string.format("%.2f", _val) or tostring(math.floor(_val))
    end

    _knob.InputBegan:Connect(function(_inp)
        if _inp.UserInputType == Enum.UserInputType.MouseButton1 then
            _dragging = true
        end
    end)

    table.insert(_connections, _InputAdapter.InputEnded:Connect(function(_inp)
        if _inp.UserInputType == Enum.UserInputType.MouseButton1 and _dragging then
            _dragging = false
        end
    end))

    table.insert(_connections, _InputAdapter.InputChanged:Connect(function(_inp)
        if _dragging and _inp.UserInputType == Enum.UserInputType.MouseMovement then
            local _w = _track.AbsoluteSize.X
            if _w > 0 then
                _setValue(_mn + math.clamp((_inp.Position.X - _track.AbsolutePosition.X) / _w, 0, 1) * (_mx - _mn))
            end
        end
    end))

    _track.InputBegan:Connect(function(_inp)
        if _inp.UserInputType == Enum.UserInputType.MouseButton1 then
            local _w = _track.AbsoluteSize.X
            if _w > 0 then
                _setValue(_mn + math.clamp((_inp.Position.X - _track.AbsolutePosition.X) / _w, 0, 1) * (_mx - _mn))
            end
        end
    end)
end

-- Cycle selector (click to rotate through options)
