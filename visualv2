        tg2.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0.02),NumberSequenceKeypoint.new(1,0.14)}); tg2.Parent = b
        b.MouseEnter:Connect(function() if activeTab ~= i then TweenService:Create(b,TweenInfo.new(0.15),{TextTransparency=0.1}):Play() end end)
        b.MouseLeave:Connect(function() if activeTab ~= i then TweenService:Create(b,TweenInfo.new(0.15),{TextTransparency=0.35}):Play() end end)
        b.MouseButton1Click:Connect(function() Visual.PlaySound("Tab",0.22,1.02); activeTab = i
            for pi = 1, 7 do tabPages[pi].Visible = false end; tabPages[Visual.getMappedPage(i,isRageMode)].Visible = true
            for bi,bb in ipairs(tabButtons) do TweenService:Create(bb,TweenInfo.new(0.25,Enum.EasingStyle.Quint),{TextTransparency=(bi==i) and 0 or 0.35}):Play() end
            TweenService:Create(tabInd,TweenInfo.new(0.35,Enum.EasingStyle.Quint),{Position=UDim2.new(0,(i-1)*width+8,1,-2),Size=UDim2.new(0,width-16,0,2)}):Play()
        end)
