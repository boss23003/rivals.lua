Visual.ErrorSystem = {
    errors = {},
    maxErrors = 100,
    enabled = true,
    callbacks = {}
}

function Visual.ErrorSystem:Log(context, error, severity)
    if not self.enabled then return end
    
    severity = severity or "ERROR"
    local entry = {
        time = os.clock(),
        context = tostring(context),
        error = tostring(error),
        severity = severity,
        stack = debug.traceback("", 2)
    }
    
    table.insert(self.errors, 1, entry)
    
    -- Limit error history
    while #self.errors > self.maxErrors do
        table.remove(self.errors)
    end
    
    -- Call registered callbacks
    for _, callback in ipairs(self.callbacks) do
        pcall(callback, entry)
    end
    
    -- Log to console
    local prefix = severity == "CRITICAL" and "[CRITICAL]" or "[ERROR]"
    warn(string.format("%s %s: %s", prefix, context, error))
end

function Visual.ErrorSystem:OnError(callback)
    if type(callback) == "function" then
        table.insert(self.callbacks, callback)
    end
end

function Visual.ErrorSystem:GetErrors(filter)
    if not filter then return self.errors end
    
    local filtered = {}
    for _, err in ipairs(self.errors) do
        if err.severity == filter or err.context:find(filter) then
            table.insert(filtered, err)
        end
    end
    return filtered
end

function Visual.ErrorSystem:Clear()
    self.errors = {}
end

-- ═══════════════════════════════════════════════════════════════
-- PERFORMANCE MONITORING SYSTEM (52 lines)
-- ═══════════════════════════════════════════════════════════════

Visual.Performance = {
    metrics = {},
    history = {},
    maxHistory = 60,
    enabled = true
}

function Visual.Performance:Start(name)
    if not self.enabled then return end
    self.metrics[name] = {start = os.clock(), calls = (self.metrics[name] and self.metrics[name].calls or 0) + 1}
end

function Visual.Performance:Stop(name)
    if not self.enabled or not self.metrics[name] then return end
    
    local metric = self.metrics[name]
    local duration = os.clock() - metric.start
    
    if not self.history[name] then
        self.history[name] = {samples = {}, total = 0, count = 0, max = 0, min = math.huge}
    end
    
    local hist = self.history[name]
    table.insert(hist.samples, duration)
    hist.total = hist.total + duration
    hist.count = hist.count + 1
    hist.max = math.max(hist.max, duration)
    hist.min = math.min(hist.min, duration)
    
    -- Limit history
    while #hist.samples > self.maxHistory do
        local removed = table.remove(hist.samples, 1)
        hist.total = hist.total - removed
        hist.count = hist.count - 1
    end
end

function Visual.Performance:GetStats(name)
    local hist = self.history[name]
    if not hist or hist.count == 0 then return nil end
    
    return {
        average = hist.total / hist.count,
        max = hist.max,
        min = hist.min,
        calls = self.metrics[name] and self.metrics[name].calls or 0,
        samples = hist.count
    }
end

function Visual.Performance:GetReport()
    local report = {}
    for name, _ in pairs(self.history) do
        report[name] = self:GetStats(name)
    end
    return report
end

function Visual.Performance:Reset()
    self.metrics = {}
    self.history = {}
end

-- ═══════════════════════════════════════════════════════════════
-- MEMORY MANAGEMENT SYSTEM (48 lines)
-- ═══════════════════════════════════════════════════════════════

Visual.Memory = {
    tracked = {},
    cleanupQueue = {},
    autoCleanup = true,
    cleanupInterval = 30
}

function Visual.Memory:Track(object, name, metadata)
    if not object then return end
    
    local id = tostring(object)
    self.tracked[id] = {
        object = object,
        name = name or "Unknown",
        created = os.clock(),
        metadata = metadata or {}
    }
end

function Visual.Memory:Untrack(object)
    if not object then return end
    local id = tostring(object)
    self.tracked[id] = nil
end

function Visual.Memory:QueueCleanup(object, delay)
    delay = delay or 0
    table.insert(self.cleanupQueue, {
        object = object,
        time = os.clock() + delay
    })
end

function Visual.Memory:ProcessCleanup()
    local now = os.clock()
    for i = #self.cleanupQueue, 1, -1 do
        local item = self.cleanupQueue[i]
        if now >= item.time then
            pcall(function()
                if item.object and item.object.Parent then
                    item.object:Destroy()
                end
            end)
            table.remove(self.cleanupQueue, i)
        end
    end
end

function Visual.Memory:GetStats()
    local count = 0
    local byType = {}
    
    for _, entry in pairs(self.tracked) do
        count = count + 1
        local objType = typeof(entry.object)
        byType[objType] = (byType[objType] or 0) + 1
    end
    
    return {
        total = count,
        byType = byType,
        queuedCleanup = #self.cleanupQueue
    }
end

function Visual.Memory:CleanupAll()
    local cleaned = 0
    for id, entry in pairs(self.tracked) do
        pcall(function()
            if entry.object and entry.object.Parent then
                entry.object:Destroy()
                cleaned = cleaned + 1
            end
        end)
        self.tracked[id] = nil
    end
    return cleaned
end

