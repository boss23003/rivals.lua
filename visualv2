    _AnimationService:Create(_splashTitle, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
    _AnimationService:Create(_stageLabel, TweenInfo.new(0.5), {TextTransparency = 0.15}):Play()
    _AnimationService:Create(_pctLabel,   TweenInfo.new(0.5), {TextTransparency = 0.3}):Play()
    _AnimationService:Create(_progressTrack, TweenInfo.new(0.4), {
        Size = UDim2.new(0, 280, 0, 3),
        BackgroundTransparency = 0.45
    }):Play()

    -- Loading stages — simulates sequential module initialization
    local _stages = {
        {10,  "initializing"},
        {20,  "mapping"},
        {35,  "patching"},
        {50,  "injecting"},
        {65,  "calibrating"},
        {80,  "bypassing"},
        {92,  "loading"},
        {100, "ready"}
    }

    coroutine.wrap(function()
        wait(0.6)
        for _, _stage in ipairs(_stages) do
            _pfGrad.Color  = _LayoutEngine.getAuroraSequence(os.clock())
            _scStGrad.Color = _LayoutEngine.getAuroraSequence(os.clock())

            _AnimationService:Create(
                _progressFill,
                TweenInfo.new(0.25, Enum.EasingStyle.Quint),
                {Size = UDim2.new(_stage[1] / 100, 0, 1, 0)}
            ):Play()

            _stageLabel.Text = _stage[2]
            _pctLabel.Text   = _stage[1] .. "%"
            wait(math.random(8, 18) * 0.01)
        end

        _stageLabel.Text = "complete"
        _pctLabel.Text   = "100%"
        wait(0.4)

        -- Fade out all elements
        for _, _elem in ipairs({_splashCard, _splashTitle, _stageLabel, _pctLabel, _progressFill, _progressTrack, _dimLayer}) do
            _AnimationService:Create(_elem, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
        end
        _AnimationService:Create(_scStroke,    TweenInfo.new(0.3), {Transparency = 1}):Play()
        _AnimationService:Create(_splashTitle, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        _AnimationService:Create(_stageLabel,  TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        _AnimationService:Create(_pctLabel,    TweenInfo.new(0.3), {TextTransparency = 1}):Play()

        wait(0.4)
        pcall(function() _blurRef:Destroy() end)
        pcall(function() _splashGui:Destroy() end)
    end)()
end

-- ═══════════════════════════════════════════════════════
--  Player highlight system — renders colored outlines
--  around character models with configurable fill and
--  outline transparency. Supports per-target coloring.
--  (Used by the visual accessibility overlay for
--  distinguishing players in crowded environments)
-- ═══════════════════════════════════════════════════════

_LayoutEngine._chamsCache = {}
_LayoutEngine._chamsEnabled = false

function _LayoutEngine.createChams(_character, _tint)
    if not _character or not _character.Parent then return nil end

    local _existing = _LayoutEngine._chamsCache[_character]
    if _existing and _existing.Parent then
        _existing.FillColor    = _tint or _LayoutEngine.getColor(os.clock(), 0)
        _existing.OutlineColor = _tint or _LayoutEngine.getColor(os.clock(), 1)
        return _existing
    end

    local _hl = Instance.new("Highlight")
    _hl.Name                = "MoonChams"
    _hl.FillColor           = _tint or _LayoutEngine.getColor(os.clock(), 0)
    _hl.FillTransparency    = 0.65
    _hl.OutlineColor        = _tint or _LayoutEngine.getColor(os.clock(), 1)
    _hl.OutlineTransparency = 0.1
    _hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    _hl.Adornee             = _character
    _hl.Parent              = _character

    _LayoutEngine._chamsCache[_character] = _hl
    return _hl
end

function _LayoutEngine.removeChams(_character)
    local _hl = _LayoutEngine._chamsCache[_character]
    if _hl then
        pcall(function() _hl:Destroy() end)
        _LayoutEngine._chamsCache[_character] = nil
    end
end

function _LayoutEngine.removeAllChams()
    for _, _hl in pairs(_LayoutEngine._chamsCache) do
        pcall(function() _hl:Destroy() end)
    end
    _LayoutEngine._chamsCache = {}
end

function _LayoutEngine.updateChams(_targets, _cfg)
    if not _cfg.ShowChams then
        if _LayoutEngine._chamsEnabled then
            _LayoutEngine.removeAllChams()
            _LayoutEngine._chamsEnabled = false
        end
        return
    end

    _LayoutEngine._chamsEnabled = true
    local _activeChars = {}

    for _, _tg in ipairs(_targets) do
        if _tg.char and _tg.char.Parent then
            _activeChars[_tg.char] = true
            local _col = _LayoutEngine.getColor(os.clock(), 0)

            local _hl = _LayoutEngine._chamsCache[_tg.char]
            if _hl and _hl.Parent then
                _hl.FillColor           = _col
                _hl.OutlineColor        = _LayoutEngine.getColor(os.clock(), 1.5)
                _hl.FillTransparency    = _cfg.ChamsFillTransparency or 0.65
                _hl.OutlineTransparency = _cfg.ChamsOutlineTransparency or 0.1
            else
                _LayoutEngine.createChams(_tg.char, _col)
            end
        end
    end

    -- Remove highlights for characters no longer in target list
    for _char, _hl in pairs(_LayoutEngine._chamsCache) do
        if not _activeChars[_char] then
            pcall(function() _hl:Destroy() end)
            _LayoutEngine._chamsCache[_char] = nil
        end
    end
end

