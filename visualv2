-- Create a full set of Drawing objects for one player's overlay
function _Renderer.createESPForPlayer(_targetPlayer)
    if _Renderer._espCache[_targetPlayer] then
        return _Renderer._espCache[_targetPlayer]
    end

    local _ok, _tagData = pcall(function()
        local _data = {}

        -- Name floating text
        _data.nameText = Drawing.new("Text")
        _data.nameText.Size         = 13
        _data.nameText.Center       = true
        _data.nameText.Outline      = true
        _data.nameText.OutlineColor = Color3.new(0, 0, 0)
        _data.nameText.Font         = 2
        _data.nameText.Visible      = false

        -- Distance indicator
        _data.distText = Drawing.new("Text")
        _data.distText.Size         = 11
        _data.distText.Center       = true
        _data.distText.Outline      = true
        _data.distText.OutlineColor = Color3.new(0, 0, 0)
        _data.distText.Font         = 2
        _data.distText.Visible      = false

        -- Health readout
        _data.healthText = Drawing.new("Text")
        _data.healthText.Size         = 11
        _data.healthText.Center       = true
        _data.healthText.Outline      = true
        _data.healthText.OutlineColor = Color3.new(0, 0, 0)
        _data.healthText.Font         = 2
        _data.healthText.Visible      = false

        -- Bounding outline (4 lines forming a rectangle)
        _data.box = {
            Drawing.new("Line"),
            Drawing.new("Line"),
            Drawing.new("Line"),
            Drawing.new("Line")
        }
        for _, _line in ipairs(_data.box) do
            _line.Thickness = 1.2
            _line.Visible   = false
        end

        -- Connection line from screen bottom to player
        _data.tracer = Drawing.new("Line")
        _data.tracer.Thickness = 1
        _data.tracer.Visible   = false

        -- Vertical health indicator bar
        _data.healthBar = {
            bg   = Drawing.new("Line"),
            fill = Drawing.new("Line")
        }
        _data.healthBar.bg.Thickness   = 3
        _data.healthBar.bg.Visible     = false
        _data.healthBar.fill.Thickness = 2
        _data.healthBar.fill.Visible   = false

        return _data
    end)

    if _ok and _tagData then
        _Renderer._espCache[_targetPlayer] = _tagData
        return _tagData
    end
    return nil
end

-- Destroy all Drawing objects for a specific player
function _Renderer.removeESPForPlayer(_targetPlayer)
    local _tagData = _Renderer._espCache[_targetPlayer]
    if not _tagData then return end

    pcall(function()
        if _tagData.nameText   then _tagData.nameText:Remove() end
        if _tagData.distText   then _tagData.distText:Remove() end
        if _tagData.healthText then _tagData.healthText:Remove() end
        if _tagData.box then
            for _, _line in ipairs(_tagData.box) do _line:Remove() end
        end
        if _tagData.tracer then _tagData.tracer:Remove() end
        if _tagData.healthBar then
            if _tagData.healthBar.bg   then _tagData.healthBar.bg:Remove() end
            if _tagData.healthBar.fill then _tagData.healthBar.fill:Remove() end
        end
    end)

    _Renderer._espCache[_targetPlayer] = nil
end

-- Remove all player tag overlays
function _Renderer.removeAllESP()
    for _player, _ in pairs(_Renderer._espCache) do
        _Renderer.removeESPForPlayer(_player)
    end
    _Renderer._espCache = {}
end

-- Hide (but don't destroy) a single player's tag set
function _Renderer.hideESPEntry(_tagData)
    if not _tagData then return end
    pcall(function()
        if _tagData.nameText   then _tagData.nameText.Visible   = false end
        if _tagData.distText   then _tagData.distText.Visible   = false end
        if _tagData.healthText then _tagData.healthText.Visible = false end
        if _tagData.box then
            for _, _line in ipairs(_tagData.box) do _line.Visible = false end
        end
        if _tagData.tracer then _tagData.tracer.Visible = false end
        if _tagData.healthBar then
            if _tagData.healthBar.bg   then _tagData.healthBar.bg.Visible   = false end
            if _tagData.healthBar.fill then _tagData.healthBar.fill.Visible = false end
        end
    end)
end

-- ═══════════════════════════════════════════════════════
--  Player Tag Update Loop — positions all tag elements
--  relative to each target's screen projection. Handles
--  visibility toggling, color theming, and off-screen
--  culling for performance.
-- ═══════════════════════════════════════════════════════

function _Renderer.updateESP(_targets, _prefs)
    -- Disable rendering when menu is open or user toggled off
    if not _prefs.ShowESP or _Renderer.isOpen then
        if _Renderer._espEnabled then
            for _, _tagData in pairs(_Renderer._espCache) do
                _Renderer.hideESPEntry(_tagData)
            end
            _Renderer._espEnabled = false
        end
        return
    end

    _Renderer._espEnabled = true

    local _cam = workspace.CurrentCamera
    if not _cam then return end

    local _vp        = _cam.ViewportSize
    local _activeSet = {}
    local _useTheme  = _prefs.ESPMatchGUI
    local _now       = os.clock()

    -- Resolve tag colors (theme-matched or custom overrides)
    local _nameColor   = _useTheme and _Renderer.getColor(_now, 0)   or (_prefs.ESPNameColor   or _TAG_PALETTE.Name)
    local _boxColor    = _useTheme and _Renderer.getColor(_now, 0.5) or (_prefs.ESPBoxColor    or _TAG_PALETTE.Box)
    local _tracerColor = _useTheme and _Renderer.getColor(_now, 1.0) or (_prefs.ESPTracerColor or _TAG_PALETTE.Tracer)
    local _distColor   = _useTheme and _Renderer.getColor(_now, 1.5) or (_prefs.ESPDistColor   or _TAG_PALETTE.Distance)

    for _, _tg in ipairs(_targets) do
        local _player = _tg.player
        local _char   = _tg.char
        local _hrp    = _tg.hrp

        if _player and _char and _hrp and _char.Parent then
            _activeSet[_player] = true

            local _tagData = _Renderer._espCache[_player] or _Renderer.createESPForPlayer(_player)
            if not _tagData then continue end

            local _pos, _onScreen = _cam:WorldToViewportPoint(_hrp.Position)

            if not _onScreen then
                _Renderer.hideESPEntry(_tagData)
                continue
            end

            -- Gather character metrics
            local _head     = _char:FindFirstChild("Head")
            local _localHRP = _ActiveUser.Character and _ActiveUser.Character:FindFirstChild("HumanoidRootPart")
            local _dist     = _localHRP and (_hrp.Position - _localHRP.Position).Magnitude or 0
            local _humanoid = _char:FindFirstChildOfClass("Humanoid")
            local _hp       = _humanoid and _humanoid.Health or 100
            local _maxHp    = _humanoid and _humanoid.MaxHealth or 100
            local _hpFrac   = math.clamp(_hp / math.max(_maxHp, 1), 0, 1)

            -- Project head and feet to screen space for bounding box
            local _headScreenPos = _head and _cam:WorldToViewportPoint(_head.Position + Vector3.new(0, 1.5, 0))
            local _footScreenPos = _cam:WorldToViewportPoint(_hrp.Position - Vector3.new(0, 3, 0))

            if _headScreenPos and _footScreenPos then
                local _top    = Vector2.new(_headScreenPos.X, _headScreenPos.Y)
                local _bottom = Vector2.new(_footScreenPos.X, _footScreenPos.Y)
                local _height = math.abs(_bottom.Y - _top.Y)
                local _width  = _height * 0.55
                local _cx     = (_top.X + _bottom.X) * 0.5

                -- Bounding outline
                if _prefs.ESPBox ~= false then
                    local _tl = Vector2.new(_cx - _width * 0.5, _top.Y)
                    local _tr = Vector2.new(_cx + _width * 0.5, _top.Y)
                    local _bl = Vector2.new(_cx - _width * 0.5, _bottom.Y)
                    local _br = Vector2.new(_cx + _width * 0.5, _bottom.Y)

                    _tagData.box[1].From = _tl; _tagData.box[1].To = _tr
                    _tagData.box[2].From = _tr; _tagData.box[2].To = _br
                    _tagData.box[3].From = _br; _tagData.box[3].To = _bl
                    _tagData.box[4].From = _bl; _tagData.box[4].To = _tl

                    for _, _line in ipairs(_tagData.box) do
                        _line.Color   = _boxColor
                        _line.Visible = true
                    end
                else
                    for _, _line in ipairs(_tagData.box) do
                        _line.Visible = false
                    end
                end

                -- Name tag above head
                _tagData.nameText.Text     = _player.DisplayName or _player.Name
                _tagData.nameText.Position = Vector2.new(_cx, _top.Y - 16)
                _tagData.nameText.Color    = _nameColor
                _tagData.nameText.Visible  = _prefs.ESPName ~= false

                -- Distance below feet
                _tagData.distText.Text     = string.format("%.0fm", _dist)
                _tagData.distText.Position = Vector2.new(_cx, _bottom.Y + 3)
                _tagData.distText.Color    = _distColor
                _tagData.distText.Visible  = _prefs.ESPDistance ~= false

                -- Health readout to the right
                _tagData.healthText.Text     = string.format("%.0f HP", _hp)
                _tagData.healthText.Position = Vector2.new(_cx + _width * 0.5 + 18, _top.Y + _height * 0.5 - 6)
                _tagData.healthText.Color    = Color3.fromRGB(255 * (1 - _hpFrac), 255 * _hpFrac, 50)
                _tagData.healthText.Visible  = _prefs.ESPHealth ~= false

                -- Vertical health bar (left side)
                if _prefs.ESPHealthBar ~= false then
                    local _barX = _cx - _width * 0.5 - 5

                    _tagData.healthBar.bg.From    = Vector2.new(_barX, _bottom.Y)
                    _tagData.healthBar.bg.To      = Vector2.new(_barX, _top.Y)
                    _tagData.healthBar.bg.Color   = Color3.fromRGB(40, 40, 40)
                    _tagData.healthBar.bg.Visible = true

                    local _fillTop = _bottom.Y - (_bottom.Y - _top.Y) * _hpFrac
                    _tagData.healthBar.fill.From    = Vector2.new(_barX, _bottom.Y)
                    _tagData.healthBar.fill.To      = Vector2.new(_barX, _fillTop)
                    _tagData.healthBar.fill.Color   = Color3.fromRGB(255 * (1 - _hpFrac), 255 * _hpFrac, 50)
                    _tagData.healthBar.fill.Visible = true
                else
                    _tagData.healthBar.bg.Visible   = false
                    _tagData.healthBar.fill.Visible = false
                end

                -- Connection line from screen bottom center
                if _prefs.ESPTracer ~= false then
                    _tagData.tracer.From    = Vector2.new(_vp.X * 0.5, _vp.Y)
                    _tagData.tracer.To      = Vector2.new(_cx, _bottom.Y)
                    _tagData.tracer.Color   = _tracerColor
                    _tagData.tracer.Visible = true
                else
                    _tagData.tracer.Visible = false
                end
            else
                _Renderer.hideESPEntry(_tagData)
            end
        end
    end

    -- Hide tags for players no longer in the active target list
    for _player, _tagData in pairs(_Renderer._espCache) do
        if not _activeSet[_player] then
            _Renderer.hideESPEntry(_tagData)
        end
    end
end

-- ═══════════════════════════════════════════════════════
--  Session Analytics — tracks interaction events and
--  maintains a running counter. Uses health-change
--  detection with a time-windowed attribution model
--  to determine which interactions were player-initiated.
-- ═══════════════════════════════════════════════════════

_Renderer._killData = {
    count        = 0,
    aimedPlayers = {},
    healthCache  = {},
    deadPlayers  = {}
}

-- Register that the user was interacting with a specific player
function _Renderer.markAimedPlayer(_targetPlayer)
    if _targetPlayer and _targetPlayer ~= _ActiveUser then
        _Renderer._killData.aimedPlayers[_targetPlayer] = os.clock()
    end
end

-- Scan all targets for health transitions and attribute eliminations
function _Renderer.updateKillTracking(_targets)
    local _kd = _Renderer._killData

    for _, _tg in ipairs(_targets or {}) do
        local _player = _tg.player
        local _char   = _tg.char

        if _player and _char and _char.Parent then
            local _hum = _char:FindFirstChildOfClass("Humanoid")
            if _hum then
                local _prevHP = _kd.healthCache[_player]
                local _curHP  = _hum.Health

                -- Detect health dropping to zero (elimination event)
                if _prevHP and _prevHP > 0 and _curHP <= 0 then
                    if _kd.aimedPlayers[_player] and not _kd.deadPlayers[_player] then
                        local _interactTime = _kd.aimedPlayers[_player]
                        -- Only attribute if interaction was within 15 seconds
                        if os.clock() - _interactTime < 15 then
                            _kd.count = _kd.count + 1
                            _kd.deadPlayers[_player] = true
                            _Renderer.NotifyKill(_player.DisplayName or _player.Name)
                        end
                    end
                end

                _kd.healthCache[_player] = _curHP

                -- Clear dead flag when player respawns
                if _curHP > 0 then
                    _kd.deadPlayers[_player] = nil
                end
            end
        end
    end

    -- Purge entries for players who left the server
    for _player, _ in pairs(_kd.aimedPlayers) do
        if not _player.Parent then
            _kd.aimedPlayers[_player] = nil
            _kd.healthCache[_player]  = nil
            _kd.deadPlayers[_player]  = nil
        end
    end

    -- Update the UI counter display
    if _Renderer.guiKills then
        _Renderer.guiKills.Text = _kd.count .. " kills"
    end
end

function _Renderer.getKillCount()
    return _Renderer._killData.count
end

function _Renderer.resetKillCount()
    _Renderer._killData.count        = 0
    _Renderer._killData.aimedPlayers = {}
    _Renderer._killData.healthCache  = {}
    _Renderer._killData.deadPlayers  = {}
end

-- ═══════════════════════════════════════════════════════
--  Camera Rotation Utility — provides automated camera
--  orbiting with configurable angular velocity. Includes
--  third-person offset support and pause-on-interaction
--  logic so the orbit stops when the user is actively
--  engaging with the experience.
--
--  Used by spectator-mode and cinematic replay features.
-- ═══════════════════════════════════════════════════════

_Renderer._rageSpin = {
    active            = false,
    speed             = 720,
    angle             = 0,
    thirdPerson       = true,
    thirdPersonOffset = 12,
    savedCameraType   = nil,
    savedCameraOffset = nil,
    lastUpdate        = 0,
    pausedForAim      = false
}

function _Renderer.startRageSpin(_prefs)
    local _rs = _Renderer._rageSpin
    if _rs.active then return end

    _rs.active            = true
    _rs.speed             = _prefs.SpinSpeed or 720
    _rs.thirdPerson       = _prefs.SpinThirdPerson ~= false
    _rs.thirdPersonOffset = _prefs.SpinCameraOffset or 12
    _rs.lastUpdate        = os.clock()
    _rs.angle             = 0
    _rs.pausedForAim      = false

    -- Save current camera state for restoration
    local _cam = workspace.CurrentCamera
    if _cam then _rs.savedCameraType = _cam.CameraType end

    local _hum = _ActiveUser.Character and _ActiveUser.Character:FindFirstChildOfClass("Humanoid")
    if _hum then _rs.savedCameraOffset = _hum.CameraOffset end

    if _rs.thirdPerson then
        _Renderer._applyThirdPerson(_rs.thirdPersonOffset)
    end
end

function _Renderer.stopRageSpin()
    local _rs = _Renderer._rageSpin
    if not _rs.active then return end

    _rs.active       = false
    _rs.pausedForAim = false

    -- Restore saved camera configuration
    local _cam = workspace.CurrentCamera
    if _cam and _rs.savedCameraType then
        _cam.CameraType = _rs.savedCameraType
    end

    local _hum = _ActiveUser.Character and _ActiveUser.Character:FindFirstChildOfClass("Humanoid")
    if _hum and _rs.savedCameraOffset then
        _hum.CameraOffset = _rs.savedCameraOffset
    end
end

function _Renderer._applyThirdPerson(_offset)
    local _hum = _ActiveUser.Character and _ActiveUser.Character:FindFirstChildOfClass("Humanoid")
    if _hum then
        _hum.CameraOffset = Vector3.new(0, 0, _offset or 12)
    end
end

function _Renderer.updateRageSpin(_hasInteraction)
    local _rs = _Renderer._rageSpin
    if not _rs.active then return end

    local _now = os.clock()
    local _dt  = _now - _rs.lastUpdate
    _rs.lastUpdate = _now

    local _char = _ActiveUser.Character
    if not _char then return end

    local _hrp = _char:FindFirstChild("HumanoidRootPart")
    if not _hrp then return end

    -- Pause rotation during active interactions
    if _hasInteraction then
        _rs.pausedForAim = true
        return
    end

    _rs.pausedForAim = false
    _rs.angle = _rs.angle + _rs.speed * _dt

    local _rad = math.rad(_rs.angle)
    _hrp.CFrame = CFrame.new(_hrp.Position) * CFrame.Angles(0, _rad, 0)

    if _rs.thirdPerson then
        _Renderer._applyThirdPerson(_rs.thirdPersonOffset)
    end
end

function _Renderer.isRageSpinActive()
    return _Renderer._rageSpin.active
end

function _Renderer.isRageSpinPaused()
    return _Renderer._rageSpin.pausedForAim
end

