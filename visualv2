    for pi = 1, 7 do tabPages[pi].Visible = false end; tabPages[Visual.getMappedPage(activeTab,isRageMode)].Visible = true
    local w = math.floor(windowW/#currentTabs); tabInd.Size = UDim2.new(0,w-16,0,2); tabInd.Position = UDim2.new(0,(activeTab-1)*w+8,1,-2)
