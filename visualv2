local _THEME_FILE = "MoonTheme_v35.json"

-- Apply a theme profile's settings to the active configuration
local function _applyThemeConfig(_uiTable)
    if not _uiTable then return end
    for _, _key in ipairs(_THEME_KEYS) do
        if _uiTable[_key] ~= nil then
            _Renderer.UIConfigs[_key] = _uiTable[_key]
        end
    end
    -- Handle custom color palette (may be Color3 or RGB array)
    if _uiTable.CustomColors and type(_uiTable.CustomColors) == "table" then
        _Renderer.UIConfigs.CustomColors = {}
        for _i, _col in ipairs(_uiTable.CustomColors) do
            if typeof(_col) == "Color3" then
                _Renderer.UIConfigs.CustomColors[_i] = _col
            elseif type(_col) == "table" and _col[1] and _col[2] and _col[3] then
                _Renderer.UIConfigs.CustomColors[_i] = Color3.fromRGB(_col[1], _col[2], _col[3])
            end
        end
    end
end

-- Load theme profiles from persistent storage
function _Renderer.LoadThemeProfiles()
    pcall(function()
        if readfile and isfile and isfile(_THEME_FILE) then
            local _raw = readfile(_THEME_FILE)
            local _ok, _data = pcall(function()
                return _DataSerializer:JSONDecode(_raw)
            end)
            if _ok and type(_data) == "table" then
                for _name, _prof in pairs(_data) do
                    if type(_prof) == "table" and type(_name) == "string" then
                        _Renderer.ThemeProfiles[_name] = _prof
                    end
                end
            end
        end
    end)
end

-- Save all theme profiles to persistent storage
function _Renderer.SaveThemeProfiles()
    pcall(function()
        if writefile then
            local _safe = {}
            for _name, _prof in pairs(_Renderer.ThemeProfiles) do
                if type(_prof) == "table" and _prof.UI then
                    _safe[_name] = {Name = _prof.Name or _name, UI = {}}
                    for _, _key in ipairs(_THEME_KEYS) do
                        _safe[_name].UI[_key] = _prof.UI[_key] ~= nil and _prof.UI[_key] or _Renderer.UIConfigs[_key]
                    end
                    if _prof.UI.CustomColors and type(_prof.UI.CustomColors) == "table" then
                        _safe[_name].UI.CustomColors = {}
                        for _i, _col in ipairs(_prof.UI.CustomColors) do
                            if typeof(_col) == "Color3" then
                                _safe[_name].UI.CustomColors[_i] = {
                                    math.floor(_col.R * 255),
                                    math.floor(_col.G * 255),
                                    math.floor(_col.B * 255)
                                }
                            elseif type(_col) == "table" and _col[1] and _col[2] and _col[3] then
                                _safe[_name].UI.CustomColors[_i] = {_col[1], _col[2], _col[3]}
                            end
                        end
                    end
                end
            end
            writefile(_THEME_FILE, _DataSerializer:JSONEncode(_safe))
        end
    end)
end

-- Switch to a named theme profile
function _Renderer.ApplyThemeProfile(_name)
    local _prof = _Renderer.ThemeProfiles[_name]
    if not _prof or not _prof.UI then return false end

    _applyThemeConfig(_prof.UI)

    -- Trigger all theme callbacks to refresh the UI
    if _Renderer.screenGui then
        for _, _cb in ipairs(_Renderer.themeCallbacks) do
            pcall(_cb)
        end
    end
    return true
end

-- Create a new profile from current settings
function _Renderer.CreateThemeProfile(_name)
    if not _name or _name == "" then return end

    local _ui = {}
    for _, _key in ipairs(_THEME_KEYS) do
        _ui[_key] = _Renderer.UIConfigs[_key]
    end
    if _Renderer.UIConfigs.CustomColors then
        _ui.CustomColors = {}
        for _i, _col in ipairs(_Renderer.UIConfigs.CustomColors) do
            _ui.CustomColors[_i] = _col
        end
    end

    _Renderer.ThemeProfiles[_name] = {
        Name = _name,
        UI   = _ui
    }
    _Renderer.SaveThemeProfiles()
end

-- ═══════════════════════════════════════════════════════
--  Configuration Export/Import — serializes all user
--  preferences to a Base64-encoded JSON string for
--  sharing. Includes both gameplay and theme settings.
-- ═══════════════════════════════════════════════════════

function _Renderer.ConfigSystem.Export(_prefs)
    local _data = {}
    for _, _key in ipairs(_PREF_KEYS) do
        if _prefs[_key] ~= nil then
            _data[_key] = _prefs[_key]
        end
    end

    -- Include theme settings under a nested key
    _data._UI = {}
    for _, _key in ipairs(_THEME_KEYS) do
        _data._UI[_key] = _Renderer.UIConfigs[_key]
    end
    if _Renderer.UIConfigs.CustomColors then
        _data._UI._CustomColors = {}
        for _i, _col in ipairs(_Renderer.UIConfigs.CustomColors) do
            _data._UI._CustomColors[_i] = {
                math.floor(_col.R * 255),
                math.floor(_col.G * 255),
                math.floor(_col.B * 255)
            }
        end
    end

    local _jsonStr = _DataSerializer:JSONEncode(_data)

    -- Base64 encode the JSON string for compact sharing
    local _encoded = nil
    pcall(function()
        local _alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
        _encoded = ""
        local _bytes = {string.byte(_jsonStr, 1, #_jsonStr)}
        local _i = 1
        while _i <= #_bytes do
            local _b1 = _bytes[_i] or 0
            local _b2 = _bytes[_i + 1] or 0
            local _b3 = _bytes[_i + 2] or 0
            local _n = _b1 * 65536 + _b2 * 256 + _b3
            local _c1 = math.floor(_n / 262144) % 64
            local _c2 = math.floor(_n / 4096) % 64
            local _c3 = math.floor(_n / 64) % 64
            local _c4 = _n % 64
            _encoded = _encoded
                .. string.sub(_alphabet, _c1 + 1, _c1 + 1)
                .. string.sub(_alphabet, _c2 + 1, _c2 + 1)
                .. (_i + 1 <= #_bytes and string.sub(_alphabet, _c3 + 1, _c3 + 1) or "=")
                .. (_i + 2 <= #_bytes and string.sub(_alphabet, _c4 + 1, _c4 + 1) or "=")
            _i = _i + 3
        end
    end)

    if _encoded then return "CFG-MOON-" .. _encoded end
    return nil
end

function _Renderer.ConfigSystem.Import(_cfgString, _prefs)
    if not _cfgString or type(_cfgString) ~= "string" then return false end

    local _encoded = _cfgString
    if _encoded:sub(1, 9) == "CFG-MOON-" then
        _encoded = _encoded:sub(10)
    end

    -- Base64 decode
    local _decoded = nil
    pcall(function()
        local _alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
        local _result = {}
        local _i = 1
        while _i <= #_encoded do
            local _c1 = string.find(_alphabet, _encoded:sub(_i, _i), 1, true) or 1
            local _c2 = string.find(_alphabet, _encoded:sub(_i + 1, _i + 1), 1, true) or 1
            local _c3 = string.find(_alphabet, _encoded:sub(_i + 2, _i + 2), 1, true)
            local _c4 = string.find(_alphabet, _encoded:sub(_i + 3, _i + 3), 1, true)

            _c1 = _c1 - 1
            _c2 = _c2 - 1
            _c3 = _c3 and (_c3 - 1) or 0
            _c4 = _c4 and (_c4 - 1) or 0

            local _n = _c1 * 262144 + _c2 * 4096 + _c3 * 64 + _c4

            table.insert(_result, math.floor(_n / 65536) % 256)
            if _encoded:sub(_i + 2, _i + 2) ~= "=" then
                table.insert(_result, math.floor(_n / 256) % 256)
            end
            if _encoded:sub(_i + 3, _i + 3) ~= "=" then
                table.insert(_result, _n % 256)
            end
            _i = _i + 4
        end
        _decoded = string.char(unpack(_result))
    end)

    if not _decoded then return false end

    local _ok, _data = pcall(function()
        return _DataSerializer:JSONDecode(_decoded)
    end)
    if not _ok or type(_data) ~= "table" then return false end

    -- Apply preference values
    for _, _key in ipairs(_PREF_KEYS) do
        if _data[_key] ~= nil then
            _prefs[_key] = _data[_key]
        end
    end

    -- Apply theme settings
    if _data._UI then
        for _, _key in ipairs(_THEME_KEYS) do
            if _data._UI[_key] ~= nil then
                _Renderer.UIConfigs[_key] = _data._UI[_key]
            end
        end
        if _data._UI._CustomColors then
            _Renderer.UIConfigs.CustomColors = {}
            for _i, _rgb in ipairs(_data._UI._CustomColors) do
                _Renderer.UIConfigs.CustomColors[_i] = Color3.fromRGB(_rgb[1], _rgb[2], _rgb[3])
            end
        end
    end

    return true
end

-- File-based save/load wrappers
function _Renderer.ConfigSystem.SaveToFile(_prefs, _name)
    _name = _name or "moon_config"
    local _str = _Renderer.ConfigSystem.Export(_prefs)
    if not _str then return false end
    pcall(function()
        if writefile then writefile(_name .. ".mooncfg", _str) end
    end)
    return _str
end

function _Renderer.ConfigSystem.LoadFromFile(_prefs, _name)
    _name = _name or "moon_config"
    local _str = nil
    pcall(function()
        if readfile and isfile and isfile(_name .. ".mooncfg") then
            _str = readfile(_name .. ".mooncfg")
        end
    end)
    if _str then
        return _Renderer.ConfigSystem.Import(_str, _prefs)
    end
    return false
end

