function Visual.getColor(t, offset)
    local cfg = Visual.UIConfigs
    if cfg.ThemeMode == 1 then
        return Visual.getAuroraColor(t, offset)
    elseif cfg.ThemeMode == 2 then
        return Color3.fromRGB(255, 255, 255):Lerp(Color3.fromRGB(180, 190, 255), math.sin(t * cfg.ColorSpeed + offset) * 0.5 + 0.5)
    elseif cfg.ThemeMode == 3 then
        return Color3.fromRGB(220, 225, 255)
    elseif cfg.ThemeMode == 4 then
        local colors = cfg.CustomColors
        local count = #colors
        if count == 0 then return Color3.new(1,1,1) end
        if count == 1 then return colors[1] end
        local idx = ((t * cfg.ColorSpeed + offset) % count)
        local i1 = math.floor(idx) % count + 1
        local i2 = (i1 % count) + 1
        local frac = idx - math.floor(idx)
        return colors[i1]:Lerp(colors[i2], frac)
    end
    return Color3.new(1,1,1)
end
function Visual.getSequence(t)
    return ColorSequence.new({
