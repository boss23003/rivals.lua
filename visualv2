        end
    end

    pcall(function()
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        UserInputService.MouseIconEnabled = true
    end)

    for _, sound in pairs(soundCache) do
        pcall(function() sound:Destroy() end)
    end
    soundCache = {}

    Visual.themeCallbacks = {}
    Visual.resetKillCount()
    Visual.Notify = function() end
    Visual.PlaySound = function() end
end

-- ═══ INIT ═══
function Visual.init(CFG, allConnections)
    allConnections = allConnections or {}
    Visual._allConnections = allConnections

    Visual.createFOVCircle()
    Visual.buildUITab(CFG, allConnections)
    Visual.buildPatchTab()
    Visual.startUpdateLoop() -- FIX: Now it's actually called here
    Visual.showLoadingScreen()

    task.delay(2.5, function()
        Visual.Notify("MOON", "v3.5 loaded successfully", 4)
    end)
end

return Visual
