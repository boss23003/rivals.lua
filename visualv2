_LayoutEngine.SoundIds = {
    Click     = "rbxassetid://6026984224",
    Toggle    = "rbxassetid://6026984224",
    Open      = "rbxassetid://9120286436",
    Close     = "rbxassetid://9120286436",
    Notify    = "rbxassetid://6026984224",
    Kill      = "rbxassetid://9118823108",
    Tab       = "rbxassetid://6026984224",
    Rage      = "rbxassetid://6026984224",
    ToggleOn  = "rbxassetid://6026984224",
    ToggleOff = "rbxassetid://6026984224",
    SliderTick = "rbxassetid://6026984224"
}

local _audioCache = {}

function _LayoutEngine.PlaySound(_name, _vol, _spd)
    local _assetId = type(_name) == "string" and _LayoutEngine.SoundIds[_name] or _name
    if not _assetId then return end
    _vol = _vol or 0.35
    _spd = _spd or 1

    local _cached = _audioCache[_assetId]
    if _cached and _cached.Parent then
        _cached.Volume = _vol
        _cached.PlaybackSpeed = _spd
        _cached:Play()
        return
    end

    local _snd = Instance.new("Sound")
    _snd.SoundId            = _assetId
    _snd.Volume             = _vol
    _snd.PlaybackSpeed      = _spd
    _snd.RollOffMode        = Enum.RollOffMode.Linear
    _snd.RollOffMaxDistance  = 0
    _snd.Parent             = _AudioController
    _audioCache[_assetId]   = _snd
    pcall(function() _snd:Play() end)
end

-- ═══════════════════════════════════════════════════════
--  Safe GUI parenting — ensures the ScreenGui is placed
--  in a valid container across different runtime contexts
--  (Studio, live server, or sandboxed environments)
-- ═══════════════════════════════════════════════════════

local function _resolveParent(_guiObject)
    local _ok = false
    if gethui then
        _ok = pcall(function() _guiObject.Parent = gethui() end)
    end
    if not _ok then
        pcall(function() _guiObject.Parent = game.CoreGui end)
    end
    if not _guiObject.Parent then
        _guiObject.Parent = _ActiveUser:WaitForChild("PlayerGui")
    end
end

-- ═══════════════════════════════════════════════════════
--  Session cleanup — removes any previous instances
--  of the UI toolkit to prevent duplicate rendering.
--  This handles hot-reload scenarios gracefully.
-- ═══════════════════════════════════════════════════════

local _legacyNames = {
    "MoonOverlay", "MoonLoad", "MoonGUI_Main", "MoonGUI",
    "SakuraGUI_v18", "SakuraGUI_v19", "SakuraGUI_v20", "SakuraGUI"
}

for _, _guiName in ipairs(_legacyNames) do
    pcall(function()
        if game.CoreGui:FindFirstChild(_guiName) then
            game.CoreGui[_guiName]:Destroy()
        end
    end)
    pcall(function()
        if gethui and gethui():FindFirstChild(_guiName) then
            gethui()[_guiName]:Destroy()
        end
    end)
end

-- Clean up leftover post-processing effects from prior sessions
for _, _child in ipairs(_RenderEnvironment:GetChildren()) do
    if _child.Name:find("MoonBlur")
       or _child.Name:find("MoonLoadBlur")
       or _child.Name:find("SakuraMainBlur") then
        pcall(function() _child:Destroy() end)
    end
end

