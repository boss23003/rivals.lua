-- ═══════════════════════════════════════════════════════
--  Adaptive color interpolation engine
--  Blends palette entries based on elapsed time to
--  produce smooth transitions for UI accent coloring.
--  Supports intensity modulation for low-vision users.
-- ═══════════════════════════════════════════════════════

function _LayoutEngine.getColor(_elapsed, _shift)
    local _prefs = _LayoutEngine.UIConfigs
    _shift = _shift or 0
    local _rate = _prefs.ColorSpeed or 0.35
    local _power = math.clamp(_prefs.ColorIntensity or 1, 0.1, 2)

    -- Minimal theme: returns a flat neutral tone, no interpolation
    if _prefs.ThemeMode == 5 then
        return Color3.fromRGB(190, 190, 200)
    end

    local _result

    if _prefs.ThemeMode == 1 then
        -- Palette A: high-contrast accessible gradients
        local _pos = ((_elapsed * _rate + _shift) % _PaletteALen)
        local _lo = math.floor(_pos) % _PaletteALen + 1
        local _hi = (_lo % _PaletteALen) + 1
        local _alpha = _pos - math.floor(_pos)
        _result = _PaletteA[_lo]:Lerp(_PaletteA[_hi], _alpha)

    elseif _prefs.ThemeMode == 2 then
        -- Palette B: subdued tones for reduced eye strain
        local _pos = ((_elapsed * _rate + _shift) % _PaletteBLen)
        local _lo = math.floor(_pos) % _PaletteBLen + 1
        local _hi = (_lo % _PaletteBLen) + 1
        local _alpha = _pos - math.floor(_pos)
        _result = _PaletteB[_lo]:Lerp(_PaletteB[_hi], _alpha)

    elseif _prefs.ThemeMode == 3 then
        -- Static theme: fixed neutral-cool accent
        _result = Color3.fromRGB(220, 225, 255)

    elseif _prefs.ThemeMode == 4 then
        -- User-defined custom palette interpolation
        local _userPalette = _prefs.CustomColors
        local _count = #_userPalette
        if _count == 0 then return Color3.new(1, 1, 1) end
        if _count == 1 then
            _result = _userPalette[1]
        else
            local _pos = ((_elapsed * _rate + _shift) % _count)
            local _lo = math.floor(_pos) % _count + 1
            local _hi = (_lo % _count) + 1
            local _alpha = _pos - math.floor(_pos)
            _result = _userPalette[_lo]:Lerp(_userPalette[_hi], _alpha)
        end
    else
        _result = Color3.fromRGB(200, 200, 210)
    end

    -- Apply intensity adjustment for accessibility
    -- Values below 1.0 reduce vibrancy, above 1.0 boost it
    if _power < 1 then
        _result = _result:Lerp(Color3.fromRGB(40, 40, 50), 1 - _power)
    elseif _power > 1 then
        local _boost = _power - 1
        _result = Color3.new(
            math.clamp(_result.R + _boost * 0.3, 0, 1),
            math.clamp(_result.G + _boost * 0.3, 0, 1),
            math.clamp(_result.B + _boost * 0.3, 0, 1)
        )
    end

    return _result
end

-- ═══════════════════════════════════════════════════════
--  Palette-A specific interpolation (used by header
--  elements that always reference the primary palette
--  regardless of the active theme mode selection)
-- ═══════════════════════════════════════════════════════

function _LayoutEngine.getAuroraColor(_elapsed, _shift)
    _shift = _shift or 0
    local _rate = 0.35
    local _pos = ((_elapsed * _rate + _shift) % _PaletteALen)
    local _lo = math.floor(_pos) % _PaletteALen + 1
    local _hi = (_lo % _PaletteALen) + 1
    local _alpha = _pos - math.floor(_pos)
    return _PaletteA[_lo]:Lerp(_PaletteA[_hi], _alpha)
end

-- ═══════════════════════════════════════════════════════
--  ColorSequence generators for UIGradient elements.
--  Respects theme mode and gradient toggle preference.
--  Falls back to solid fills when gradients disabled.
-- ═══════════════════════════════════════════════════════

function _LayoutEngine.getSequence(_elapsed)
    local _prefs = _LayoutEngine.UIConfigs
    -- Minimal/static themes and disabled gradient → solid fill
    if _prefs.ThemeMode == 5 or not _prefs.GradientEnabled or _prefs.ThemeMode == 3 then
        return ColorSequence.new(_LayoutEngine.getColor(_elapsed, 0))
    end
    return ColorSequence.new({
        ColorSequenceKeypoint.new(0,   _LayoutEngine.getColor(_elapsed, 0)),
        ColorSequenceKeypoint.new(0.5, _LayoutEngine.getColor(_elapsed, 2)),
        ColorSequenceKeypoint.new(1,   _LayoutEngine.getColor(_elapsed, 4))
    })
end

function _LayoutEngine.getAuroraSequence(_elapsed)
    local _prefs = _LayoutEngine.UIConfigs
    if _prefs.ThemeMode == 5 or not _prefs.GradientEnabled then
        return ColorSequence.new(_LayoutEngine.getColor(_elapsed, 0))
    end
    if _prefs.ThemeMode == 3 then
        return ColorSequence.new(_LayoutEngine.getColor(_elapsed, 0))
    end
    return ColorSequence.new({
        ColorSequenceKeypoint.new(0,    _LayoutEngine.getAuroraColor(_elapsed, 0)),
        ColorSequenceKeypoint.new(0.25, _LayoutEngine.getAuroraColor(_elapsed, 1.2)),
        ColorSequenceKeypoint.new(0.5,  _LayoutEngine.getAuroraColor(_elapsed, 2.4)),
        ColorSequenceKeypoint.new(0.75, _LayoutEngine.getAuroraColor(_elapsed, 3.6)),
        ColorSequenceKeypoint.new(1,    _LayoutEngine.getAuroraColor(_elapsed, 4.8))
    })
end

-- ═══════════════════════════════════════════════════════
--  Stroke color calculation — derives border tones
--  from the current palette with darkening applied
--  for sufficient contrast against fill backgrounds
-- ═══════════════════════════════════════════════════════

function _LayoutEngine.getStrokeColor(_elapsed, _shift)
    _shift = _shift or 0
    local _base = _LayoutEngine.getColor(_elapsed, _shift)
    local _mix = 1 - (_LayoutEngine.UIConfigs.StrokeTransparency or 0.15)
    return _base:Lerp(Color3.new(0, 0, 0), 0.7 * _mix)
end

function _LayoutEngine.getStrokeSequence(_elapsed)
    local _prefs = _LayoutEngine.UIConfigs
    if _prefs.ThemeMode == 5 or not _prefs.GradientEnabled then
        return ColorSequence.new(_LayoutEngine.getStrokeColor(_elapsed, 0))
    end
    return ColorSequence.new({
        ColorSequenceKeypoint.new(0,   _LayoutEngine.getStrokeColor(_elapsed, 0)),
        ColorSequenceKeypoint.new(0.5, _LayoutEngine.getStrokeColor(_elapsed, 2)),
        ColorSequenceKeypoint.new(1,   _LayoutEngine.getStrokeColor(_elapsed, 4))
    })
end

-- Public API surface for external modules that need
