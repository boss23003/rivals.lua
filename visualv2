-- ═══════════════════════════════════════════════════════
--  Viewport Guide Circle — renders a circular overlay
--  at screen center to help users gauge distances and
--  alignment. Uses the Drawing API for sub-pixel
--  rendering outside the GUI layer.
--
--  Commonly used for aim-training assist overlays and
--  crosshair visualization in supported experiences.
-- ═══════════════════════════════════════════════════════

_Renderer._fovCircle  = nil
_Renderer._fovVisible = false

function _Renderer.createFOVCircle()
    if _Renderer._fovCircle then return _Renderer._fovCircle end

    local _ok, _circle = pcall(function()
        local _c = Drawing.new("Circle")
        _c.Thickness    = 1.5
        _c.NumSides     = 128
        _c.Radius       = 100
        _c.Filled       = false
        _c.Visible      = false
        _c.Transparency = 0.8
        _c.Color        = Color3.fromRGB(200, 200, 255)
        return _c
    end)

    if _ok and _circle then
        _Renderer._fovCircle = _circle
        return _circle
    end
    return nil
end

function _Renderer.updateFOVCircle(_prefs, _forceHide)
    local _circle = _Renderer._fovCircle or _Renderer.createFOVCircle()
    if not _circle then return end

    -- Hide when menu is open, forced, or user disabled the guide
    if _forceHide or _Renderer.isOpen or not _prefs.ShowFOV then
        _circle.Visible       = false
        _Renderer._fovVisible = false
        return
    end

    local _cam = workspace.CurrentCamera
    if not _cam then
        _circle.Visible = false
        return
    end

    local _vp      = _cam.ViewportSize
    local _centerX = _vp.X * 0.5
    local _centerY = _vp.Y * 0.5
    local _scale   = math.min(_vp.X, _vp.Y) / 1080
    local _radius  = (_prefs.FOVRadius or 100) * _scale

    _circle.Position     = Vector2.new(_centerX, _centerY)
    _circle.Radius       = _radius
    _circle.NumSides     = 128
    _circle.Thickness    = _prefs.FOVThickness or 1.5
    _circle.Transparency = _prefs.FOVTransparency or 0.8

    -- Color can match the active theme or use a custom override
    if _prefs.FOVMatchGUI then
        _circle.Color = _Renderer.getColor(os.clock(), 0.5)
    else
        _circle.Color = _prefs.FOVColor or Color3.fromRGB(200, 200, 255)
    end

    _circle.Visible       = true
    _Renderer._fovVisible = true
end

function _Renderer.hideFOVCircle()
    if _Renderer._fovCircle then
        _Renderer._fovCircle.Visible = false
        _Renderer._fovVisible        = false
    end
end

