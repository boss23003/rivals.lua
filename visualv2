function Visual.getColor(t, offset)
    local cfg = Visual.UIConfigs
    offset = offset or 0
    local spd = cfg.ColorSpeed or 0.35
    local intensity = math.clamp(cfg.ColorIntensity or 1, 0, 2)

    if cfg.ThemeMode == 5 then
        return Color3.fromRGB(190, 190, 200)
    end

    local color

    if cfg.ThemeMode == 1 then
        local idx = ((t * spd + offset) % auroraCount)
        local i1 = math.floor(idx) % auroraCount + 1
        local i2 = (i1 % auroraCount) + 1
        local frac = idx - math.floor(idx)
        color = auroraColors[i1]:Lerp(auroraColors[i2], frac)
    elseif cfg.ThemeMode == 2 then
        local idx = ((t * spd + offset) % moonCount)
        local i1 = math.floor(idx) % moonCount + 1
        local i2 = (i1 % moonCount) + 1
        local frac = idx - math.floor(idx)
        color = moonThemeColors[i1]:Lerp(moonThemeColors[i2], frac)
    elseif cfg.ThemeMode == 3 then
        color = Color3.fromRGB(220, 225, 255)
    elseif cfg.ThemeMode == 4 then
        local colors = cfg.CustomColors
        local count = #colors
        if count == 0 then return Color3.new(1, 1, 1) end
        if count == 1 then color = colors[1]
        else
            local idx = ((t * spd + offset) % count)
            local i1 = math.floor(idx) % count + 1
            local i2 = (i1 % count) + 1
            local frac = idx - math.floor(idx)
            color = colors[i1]:Lerp(colors[i2], frac)
        end
    else
        color = Color3.fromRGB(200, 200, 210)
    end

    if intensity < 1 then
        color = color:Lerp(Color3.fromRGB(190, 190, 200), 1 - intensity)
    elseif intensity > 1 then
        local boost = intensity - 1
        color = Color3.new(
            math.clamp(color.R + boost * 0.3, 0, 1),
            math.clamp(color.G + boost * 0.3, 0, 1),
            math.clamp(color.B + boost * 0.3, 0, 1)
        )
    end

    return color
end

function Visual.getSequence(t)
    local cfg = Visual.UIConfigs
    if cfg.ThemeMode == 5 or not cfg.GradientEnabled or cfg.ThemeMode == 3 then
        local c = Visual.getColor(t, 0)
        return ColorSequence.new(c)
    end
    return ColorSequence.new({
        ColorSequenceKeypoint.new(0, Visual.getColor(t, 0)),
        ColorSequenceKeypoint.new(0.5, Visual.getColor(t, 2)),
        ColorSequenceKeypoint.new(1, Visual.getColor(t, 4))
    })
end

function Visual.getStrokeColor(t, offset)
    offset = offset or 0
    local base = Visual.getColor(t, offset)
    local mix = 1 - (Visual.UIConfigs.StrokeTransparency or 0.15)
    return base:Lerp(Color3.new(0, 0, 0), 0.7 * mix)
end

function Visual.getStrokeSequence(t)
    local cfg = Visual.UIConfigs
    if cfg.ThemeMode == 5 or not cfg.GradientEnabled then
        local c = Visual.getStrokeColor(t, 0)
        return ColorSequence.new(c)
    end
    return ColorSequence.new({
        ColorSequenceKeypoint.new(0, Visual.getStrokeColor(t, 0)),
        ColorSequenceKeypoint.new(0.5, Visual.getStrokeColor(t, 2)),
        ColorSequenceKeypoint.new(1, Visual.getStrokeColor(t, 4))
    })
end

