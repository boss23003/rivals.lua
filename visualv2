-- Range slider with draggable knob
function _LayoutEngine.makeSlider(_pi, _text, _key, _mn, _mx, _step, _cfg, _connections)
    _connections = _connections or {}

    local _row = Instance.new("Frame")
    _row.Size                  = UDim2.new(1, -4, 0, 42)
    _row.BackgroundTransparency = 0.85
    _row.ZIndex                = 18
    _row.LayoutOrder           = _nextOrder(_pi)
