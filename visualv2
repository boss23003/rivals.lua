        _evRow, TweenInfo.new(0.28, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
        {Size = UDim2.new(1, 0, 0, 22)}
    ):Play()
    _AnimationService:Create(_erLabel, TweenInfo.new(0.24), {TextTransparency = 0}):Play()

    -- Auto-dismiss after delay
    coroutine.wrap(function()
        wait(2.1)
        _AnimationService:Create(_erLabel, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
        local _collapseAnim = _AnimationService:Create(
