function Visual.updateESP(targets, CFG)
    if not CFG.ShowESP or Visual.isOpen then
        if Visual._espEnabled then
            for _, esp in pairs(Visual._espCache) do
                Visual.hideESPEntry(esp)
            end
            Visual._espEnabled = false
        end
        return
    end
    Visual._espEnabled = true
    local cam = workspace.CurrentCamera
    if not cam then return end
    local vp = cam.ViewportSize
    local activeSet = {}
    local useGUIColor = CFG.ESPMatchGUI
    local t = os.clock()
    local espNameColor = useGUIColor and Visual.getColor(t, 0) or (CFG.ESPNameColor or ESP_COLORS.Name)
    local espBoxColor = useGUIColor and Visual.getColor(t, 0.5) or (CFG.ESPBoxColor or ESP_COLORS.Box)
    local espTracerColor = useGUIColor and Visual.getColor(t, 1.0) or (CFG.ESPTracerColor or ESP_COLORS.Tracer)
    local espDistColor = useGUIColor and Visual.getColor(t, 1.5) or (CFG.ESPDistColor or ESP_COLORS.Distance)

    for _, tg in ipairs(targets) do
        local player = tg.player
        local char = tg.char
        local hrp = tg.hrp
        if player and char and hrp and char.Parent then
            activeSet[player] = true
            local esp = Visual._espCache[player] or Visual.createESPForPlayer(player)
            if not esp then continue end

            local pos, onScreen = cam:WorldToViewportPoint(hrp.Position)
            if not onScreen then
                Visual.hideESPEntry(esp)
                continue
            end

            local head = char:FindFirstChild("Head")
            local localHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local dist = localHRP and (hrp.Position - localHRP.Position).Magnitude or 0
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            local hp = humanoid and humanoid.Health or 100
            local maxHp = humanoid and humanoid.MaxHealth or 100
            local hpFrac = math.clamp(hp / math.max(maxHp, 1), 0, 1)

            local headPos = head and cam:WorldToViewportPoint(head.Position + Vector3.new(0, 1.5, 0))
            local footPos = cam:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))

            if headPos and footPos then
                local top = Vector2.new(headPos.X, headPos.Y)
                local bottom = Vector2.new(footPos.X, footPos.Y)
                local height = math.abs(bottom.Y - top.Y)
                local width = height * 0.55
                local cx = (top.X + bottom.X) * 0.5

                if CFG.ESPBox ~= false then
                    local tl = Vector2.new(cx - width * 0.5, top.Y)
                    local tr = Vector2.new(cx + width * 0.5, top.Y)
                    local bl = Vector2.new(cx - width * 0.5, bottom.Y)
                    local br = Vector2.new(cx + width * 0.5, bottom.Y)
                    esp.box[1].From = tl; esp.box[1].To = tr
                    esp.box[2].From = tr; esp.box[2].To = br
                    esp.box[3].From = br; esp.box[3].To = bl
                    esp.box[4].From = bl; esp.box[4].To = tl
                    for _, line in ipairs(esp.box) do
                        line.Color = espBoxColor
                        line.Visible = true
                    end
                else
                    for _, line in ipairs(esp.box) do line.Visible = false end
                end

                esp.nameText.Text = player.DisplayName or player.Name
                esp.nameText.Position = Vector2.new(cx, top.Y - 16)
                esp.nameText.Color = espNameColor
                esp.nameText.Visible = CFG.ESPName ~= false

                esp.distText.Text = string.format("%.0fm", dist)
                esp.distText.Position = Vector2.new(cx, bottom.Y + 3)
                esp.distText.Color = espDistColor
                esp.distText.Visible = CFG.ESPDistance ~= false

                esp.healthText.Text = string.format("%.0f HP", hp)
                esp.healthText.Position = Vector2.new(cx + width * 0.5 + 18, top.Y + height * 0.5 - 6)
                esp.healthText.Color = Color3.fromRGB(255 * (1 - hpFrac), 255 * hpFrac, 50)
                esp.healthText.Visible = CFG.ESPHealth ~= false

                if CFG.ESPHealthBar ~= false then
                    local barX = cx - width * 0.5 - 5
                    esp.healthBar.bg.From = Vector2.new(barX, bottom.Y)
                    esp.healthBar.bg.To = Vector2.new(barX, top.Y)
                    esp.healthBar.bg.Color = Color3.fromRGB(40, 40, 40)
                    esp.healthBar.bg.Visible = true
                    local fillTop = bottom.Y - (bottom.Y - top.Y) * hpFrac
                    esp.healthBar.fill.From = Vector2.new(barX, bottom.Y)
                    esp.healthBar.fill.To = Vector2.new(barX, fillTop)
                    esp.healthBar.fill.Color = Color3.fromRGB(255 * (1 - hpFrac), 255 * hpFrac, 50)
                    esp.healthBar.fill.Visible = true
                else
                    esp.healthBar.bg.Visible = false
                    esp.healthBar.fill.Visible = false
                end

                if CFG.ESPTracer ~= false then
                    esp.tracer.From = Vector2.new(vp.X * 0.5, vp.Y)
                    esp.tracer.To = Vector2.new(cx, bottom.Y)
                    esp.tracer.Color = espTracerColor
                    esp.tracer.Visible = true
                else
                    esp.tracer.Visible = false
                end
            else
                Visual.hideESPEntry(esp)
            end
        end
    end

    for player, esp in pairs(Visual._espCache) do
        if not activeSet[player] then
            Visual.hideESPEntry(esp)
        end
    end
end

-- ═══ KILL TRACKING ═══
Visual._killData = {
    count = 0,
    aimedPlayers = {},
    healthCache = {},
    deadPlayers = {}
}

function Visual.markAimedPlayer(player)
    if player and player ~= LocalPlayer then
        Visual._killData.aimedPlayers[player] = os.clock()
    end
end

function Visual.updateKillTracking(targets)
    local kd = Visual._killData
    for _, tg in ipairs(targets or {}) do
        local player = tg.player
        local char = tg.char
        if player and char and char.Parent then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                local prevHP = kd.healthCache[player]
                local curHP = hum.Health
                if prevHP and prevHP > 0 and curHP <= 0 then
                    if kd.aimedPlayers[player] and not kd.deadPlayers[player] then
                        local aimTime = kd.aimedPlayers[player]
                        if os.clock() - aimTime < 15 then
                            kd.count = kd.count + 1
                            kd.deadPlayers[player] = true
                            Visual.NotifyKill(player.DisplayName or player.Name)
                        end
                    end
                end
                kd.healthCache[player] = curHP
                if curHP > 0 then
                    kd.deadPlayers[player] = nil
                end
            end
        end
    end
    for player, _ in pairs(kd.aimedPlayers) do
        if not player.Parent then
            kd.aimedPlayers[player] = nil
            kd.healthCache[player] = nil
            kd.deadPlayers[player] = nil
        end
    end
    if Visual.guiKills then
        Visual.guiKills.Text = kd.count .. " kills"
    end
end

function Visual.getKillCount()
    return Visual._killData.count
end

function Visual.resetKillCount()
    Visual._killData.count = 0
    Visual._killData.aimedPlayers = {}
    Visual._killData.healthCache = {}
    Visual._killData.deadPlayers = {}
end

-- ═══ RAGE SPIN ═══
Visual._rageSpin = {
    active = false,
    speed = 720,
    angle = 0,
    thirdPerson = true,
    thirdPersonOffset = 12,
    savedCameraType = nil,
    savedCameraOffset = nil,
    lastUpdate = 0,
    pausedForAim = false
}

function Visual.startRageSpin(CFG)
    local rs = Visual._rageSpin
    if rs.active then return end
    rs.active = true
    rs.speed = CFG.SpinSpeed or 720
    rs.thirdPerson = CFG.SpinThirdPerson ~= false
    rs.thirdPersonOffset = CFG.SpinCameraOffset or 12
    rs.lastUpdate = os.clock()
    rs.angle = 0
    rs.pausedForAim = false
    local cam = workspace.CurrentCamera
    if cam then rs.savedCameraType = cam.CameraType end
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if hum then rs.savedCameraOffset = hum.CameraOffset end
    if rs.thirdPerson then Visual._applyThirdPerson(rs.thirdPersonOffset) end
end

function Visual.stopRageSpin()
    local rs = Visual._rageSpin
    if not rs.active then return end
    rs.active = false
    rs.pausedForAim = false
    local cam = workspace.CurrentCamera
    if cam and rs.savedCameraType then cam.CameraType = rs.savedCameraType end
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if hum and rs.savedCameraOffset then hum.CameraOffset = rs.savedCameraOffset end
end

function Visual._applyThirdPerson(offset)
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if hum then hum.CameraOffset = Vector3.new(0, 0, offset or 12) end
end

function Visual.updateRageSpin(hasTarget)
    local rs = Visual._rageSpin
    if not rs.active then return end
    local now = os.clock()
    local dt = now - rs.lastUpdate
    rs.lastUpdate = now
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if hasTarget then
        rs.pausedForAim = true
        return
    end
    rs.pausedForAim = false
    rs.angle = rs.angle + rs.speed * dt
    local rad = math.rad(rs.angle)
    hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, rad, 0)
    if rs.thirdPerson then Visual._applyThirdPerson(rs.thirdPersonOffset) end
end

function Visual.isRageSpinActive()
    return Visual._rageSpin.active
end

function Visual.isRageSpinPaused()
    return Visual._rageSpin.pausedForAim
end

