-- ═══════════════════════════════════════════════════════
--  Menu open/close with animated transitions,
--  blur effects, and mouse state management
-- ═══════════════════════════════════════════════════════

local _menuOpen = false
_LayoutEngine.isOpen = false
local _savedMouseBehavior, _savedMouseIconEnabled

function _LayoutEngine.openMenu(_cfg)
    _menuOpen = true
    _LayoutEngine.isOpen = true

    _mainWindow.Visible   = true
    _focusDim.Visible     = true
    _bgOverlay.Visible    = true
    _crescentCanvas.Visible = true
    _enhanceBtn.Visible   = true

    _winW, _winH = _LayoutEngine.getWS(_cfg)

    _focusDim.BackgroundTransparency = 1
    _bgOverlay.BackgroundTransparency = 1

    _AnimationService:Create(_focusDim, TweenInfo.new(0.3), {BackgroundTransparency = 0.75}):Play()
    _AnimationService:Create(_bgOverlay, TweenInfo.new(0.35), {BackgroundTransparency = 0.32}):Play()

    _mainWindow.Size     = UDim2.new(0, _winW * 0.88, 0, _winH * 0.88)
    _mainWindow.Position = UDim2.new(0.5, -_winW * 0.44, 0.5, -_winH * 0.44)
    _mainWindow.BackgroundTransparency = 0.5

    _AnimationService:Create(
        _mainWindow,
        TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {
            Size                  = UDim2.new(0, _winW, 0, _winH),
            Position              = UDim2.new(0.5, -_winW / 2, 0.5, -_winH / 2),
            BackgroundTransparency = 0.08
        }
    ):Play()

    _LayoutEngine.PlaySound("Open", 0.28, 1)

    pcall(function()
        _savedMouseBehavior    = _InputAdapter.MouseBehavior
        _savedMouseIconEnabled = _InputAdapter.MouseIconEnabled
        _InputAdapter.MouseBehavior  = Enum.MouseBehavior.Default
        _InputAdapter.MouseIconEnabled = true
    end)
end

function _LayoutEngine.closeMenu(_cfg)
    _menuOpen = false
    _LayoutEngine.isOpen = false

    _AnimationService:Create(_focusDim, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
    _AnimationService:Create(_bgOverlay, TweenInfo.new(0.25), {BackgroundTransparency = 1}):Play()
    _AnimationService:Create(
        _mainWindow,
        TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.In),
        {
            Size                  = UDim2.new(0, _winW * 0.88, 0, _winH * 0.88),
            BackgroundTransparency = 1
        }
    ):Play()

    _LayoutEngine.PlaySound("Close", 0.22, 1)

    if _LayoutEngine._onMenuClose then
        _LayoutEngine._onMenuClose()
    end

    _enhanceBtn.Visible = false

    task.delay(0.3, function()
        if not _menuOpen then
            _mainWindow.Visible     = false
            _focusDim.Visible       = false
            _bgOverlay.Visible      = false
            _crescentCanvas.Visible = false
        end
    end)

    pcall(function()
        if _savedMouseBehavior then
            _InputAdapter.MouseBehavior = _savedMouseBehavior
        end
        if _savedMouseIconEnabled ~= nil then
            _InputAdapter.MouseIconEnabled = _savedMouseIconEnabled
        end
    end)
end

-- Drag handler — called from external input loop
function _LayoutEngine.handleDrag(_inputPos)
    if _LayoutEngine._dragState.drag and _LayoutEngine._dragState.start and _LayoutEngine._dragState.pos then
        local _delta = _inputPos - _LayoutEngine._dragState.start
        _mainWindow.Position = UDim2.new(
            _LayoutEngine._dragState.pos.X.Scale,
            _LayoutEngine._dragState.pos.X.Offset + _delta.X,
            _LayoutEngine._dragState.pos.Y.Scale,
            _LayoutEngine._dragState.pos.Y.Offset + _delta.Y
        )
    end
    if _LayoutEngine._bfDrag.drag and _LayoutEngine._bfDrag.start and _LayoutEngine._bfDrag.pos then
        local _delta = _inputPos - _LayoutEngine._bfDrag.start
        _keybindPanel.Position = UDim2.new(
            _LayoutEngine._bfDrag.pos.X.Scale,
            _LayoutEngine._bfDrag.pos.X.Offset + _delta.X,
            _LayoutEngine._bfDrag.pos.Y.Scale,
            _LayoutEngine._bfDrag.pos.Y.Offset + _delta.Y
        )
    end
end

