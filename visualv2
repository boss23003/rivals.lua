local function applyUIConfig(uiTable)
    if not uiTable then return end
    for _, key in ipairs(UI_CONFIG_KEYS) do
        if uiTable[key] ~= nil then
            Visual.UIConfigs[key] = uiTable[key]
        end
    end
    if uiTable.CustomColors and type(uiTable.CustomColors) == "table" then
        Visual.UIConfigs.CustomColors = {}
        for i, col in ipairs(uiTable.CustomColors) do
            if typeof(col) == "Color3" then
                Visual.UIConfigs.CustomColors[i] = col
            elseif type(col) == "table" and col[1] and col[2] and col[3] then
                Visual.UIConfigs.CustomColors[i] = Color3.fromRGB(col[1], col[2], col[3])
            end
        end
    end
end

function Visual.LoadThemeProfiles()
    pcall(function()
        if readfile and isfile and isfile(THEME_PROFILE_FILE) then
            local raw = readfile(THEME_PROFILE_FILE)
            local ok, data = pcall(function()
                return HttpService:JSONDecode(raw)
            end)
            if ok and type(data) == "table" then
                for name, prof in pairs(data) do
                    if type(prof) == "table" and type(name) == "string" then
                        Visual.ThemeProfiles[name] = prof
                    end
                end
            end
        end
    end)
end

function Visual.SaveThemeProfiles()
    pcall(function()
        if writefile then
            local safe = {}
            for name, prof in pairs(Visual.ThemeProfiles) do
                if type(prof) == "table" and prof.UI then
                    safe[name] = {Name = prof.Name or name, UI = {}}
                    for _, key in ipairs(UI_CONFIG_KEYS) do
                        safe[name].UI[key] = prof.UI[key] ~= nil and prof.UI[key] or Visual.UIConfigs[key]
                    end
                    if prof.UI.CustomColors and type(prof.UI.CustomColors) == "table" then
                        safe[name].UI.CustomColors = {}
                        for i, col in ipairs(prof.UI.CustomColors) do
                            if typeof(col) == "Color3" then
                                safe[name].UI.CustomColors[i] = {
                                    math.floor(col.R * 255),
                                    math.floor(col.G * 255),
                                    math.floor(col.B * 255)
                                }
                            elseif type(col) == "table" and col[1] and col[2] and col[3] then
                                safe[name].UI.CustomColors[i] = {col[1], col[2], col[3]}
                            end
                        end
                    end
                end
            end
            writefile(THEME_PROFILE_FILE, HttpService:JSONEncode(safe))
        end
    end)
end

