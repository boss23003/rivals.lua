-- ═══ MAIN UPDATE LOOP ═══
Visual._updateConnection = nil
Visual._lastFPSUpdate = 0
Visual._frameCount = 0
Visual._currentFPS = 60
Visual._lastGradientSweep = 0

function Visual.startUpdateLoop()
    if Visual._updateConnection then return end

    Visual._updateConnection = game:GetService("RunService").RenderStepped:Connect(function()
        local t = os.clock()

        -- FPS
        Visual._frameCount = Visual._frameCount + 1
        if t - Visual._lastFPSUpdate >= 1 then
            Visual._currentFPS = Visual._frameCount
            Visual._frameCount = 0
            Visual._lastFPSUpdate = t
            if Visual.guiFPS then
                Visual.guiFPS.Text = Visual._currentFPS .. " fps"
            end
        end

        -- Watermark time
        if Visual.wmTime then
            Visual.wmTime.Text = os.date("%H:%M:%S")
        end

        -- Ping
        if Visual.guiPing then
            pcall(function()
                local ping = game:GetService("Stats"):FindFirstChild("PerformanceStats")
                if ping then
                    local p = ping:FindFirstChild("Ping")
                    if p then Visual.guiPing.Text = math.floor(p:GetValue()) .. "ms" end
                end
            end)
        end

        -- Color Engine
        local seq = Visual.getSequence(t)
        local stSeq = Visual.getStrokeSequence(t)

        -- Sweep-update gradients so the whole UI actually changes theme.
        -- Throttled to avoid heavy per-frame descendant scans.
        if (t - (Visual._lastGradientSweep or 0)) >= 0.08 then
            Visual._lastGradientSweep = t
            local function applyTo(root)
                if not root then return end
                for _, d in ipairs(root:GetDescendants()) do
                    if d:IsA("UIGradient") then
                        if d.Parent and d.Parent:IsA("UIStroke") then
                            d.Color = stSeq
                        else
                            d.Color = seq
                        end
                    end
                end
            end
            pcall(function()
                applyTo(Visual.gui)
                applyTo(Visual.screenGui)
            end)
        end

        -- Apply UITransparency dynamically if Open
        local uiAlpha = Visual.UIConfigs.UITransparency or 0.15
        pcall(function()
            if Visual.W and Visual.isOpen then
                Visual.W.BackgroundTransparency = 0.08 + uiAlpha * 0.5
            end
        end)

        -- Watermark
        pcall(function()
            if Visual._wmGrad then Visual._wmGrad.Color = seq end
            if Visual._wmStGrad then Visual._wmStGrad.Color = seq end
            if Visual._wmTitleGrad then Visual._wmTitleGrad.Color = seq end
            if Visual._wmTimeGrad then Visual._wmTimeGrad.Color = seq end
        end)

        -- Main window stroke + indicators
        pcall(function()
            if Visual._gStGrad then Visual._gStGrad.Color = seq end
            if Visual._tabIndGrad then Visual._tabIndGrad.Color = seq end
            if Visual._tLGrad then Visual._tLGrad.Color = seq end
        end)

        -- Conditional background animation
        pcall(function()
            if Visual.UIConfigs.BackgroundAnimate then
                if Visual._mainGrad then Visual._mainGrad.Color = seq end
            end
            if Visual.UIConfigs.TopBarAnimate then
                if Visual._titleBarGrad then Visual._titleBarGrad.Color = seq end
                if Visual._tabBarGrad then Visual._tabBarGrad.Color = seq end
            end
        end)

        -- FPS/kills/ping gradients
        pcall(function()
            if Visual._fpsGrad then Visual._fpsGrad.Color = seq end
            if Visual._killsGrad then Visual._killsGrad.Color = seq end
            if Visual._pingGrad then Visual._pingGrad.Color = seq end
            if Visual._statusGrad then Visual._statusGrad.Color = seq end
        end)

        -- Moon button
        pcall(function()
            if Visual._moonBtnGrad then Visual._moonBtnGrad.Color = seq end
            if Visual._moonBtnTxtGrad then Visual._moonBtnTxtGrad.Color = seq end
            if Visual._closeBtnG then Visual._closeBtnG.Color = seq end
            if Visual._minBtnG then Visual._minBtnG.Color = seq end
        end)

        -- Binds
        pcall(function()
            if Visual._bindsGrad then Visual._bindsGrad.Color = seq end
            if Visual._bfStGrad then Visual._bfStGrad.Color = seq end
            if Visual._bindsTitleGrad then Visual._bindsTitleGrad.Color = seq end
        end)

        -- HUD
        pcall(function()
            if Visual._hudGrad then Visual._hudGrad.Color = seq end
            if Visual._hudStGrad then Visual._hudStGrad.Color = seq end
        end)

        -- Moon crescent
        pcall(function()
            if Visual._moonOuterGrad then Visual._moonOuterGrad.Color = seq end
        end)

        -- Full aurora
        pcall(function()
            if Visual._fullAuroraGrad then Visual._fullAuroraGrad.Color = seq end
        end)

        -- Rage overlay
        pcall(function()
            if Visual._rageOverlay and Visual.isRageMode then
                local rageSeq = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(
                        255,
                        math.floor(60 + math.sin(t * 2) * 30),
                        math.floor(90 + math.cos(t * 1.5) * 40)
                    )),
                    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(
                        math.floor(180 + math.sin(t * 1.7) * 40),
                        50,
                        math.floor(150 + math.cos(t * 2.1) * 50)
                    )),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(
                        255,
                        math.floor(120 + math.sin(t * 2.5) * 60),
                        math.floor(120 + math.cos(t * 1.3) * 50)
                    ))
                })
                local rg = Visual._rageOverlay:FindFirstChildOfClass("UIGradient")
                if rg then
                    rg.Color = rageSeq
                    rg.Rotation = 45 + math.sin(t * 0.5) * 30
                end
            end
        end)

        -- Stars
        pcall(function()
            if Visual.guiStars then
                for i, star in ipairs(Visual.guiStars) do
                    if star and star.Parent then
                        star.BackgroundTransparency = 0.5 + 0.3 * math.sin(t * (1.2 + i * 0.15) + i)
                    end
                end
            end
        end)

        -- Theme callbacks
        for _, cb in ipairs(Visual.themeCallbacks) do
            pcall(cb)
        end
    end)
end

