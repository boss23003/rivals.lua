-- ADVANCED CACHING SYSTEM (55 lines)
-- ═══════════════════════════════════════════════════════════════

Visual.Cache = {
    stores = {},
    defaultTTL = 1.0,
    maxSize = 200
}

function Visual.Cache:CreateStore(name, ttl, maxSize)
    self.stores[name] = {
        data = {},
        ttl = ttl or self.defaultTTL,
        maxSize = maxSize or self.maxSize,
        hits = 0,
        misses = 0
    }
end

function Visual.Cache:Get(storeName, key)
    local store = self.stores[storeName]
    if not store then return nil end
    
    local entry = store.data[key]
    if not entry then
        store.misses = store.misses + 1
        return nil
    end
    
    -- Check if expired
    if os.clock() - entry.time > store.ttl then
        store.data[key] = nil
        store.misses = store.misses + 1
        return nil
    end
    
    store.hits = store.hits + 1
    entry.lastAccess = os.clock()
    return entry.value
end

function Visual.Cache:Set(storeName, key, value)
    local store = self.stores[storeName]
    if not store then
        self:CreateStore(storeName)
        store = self.stores[storeName]
    end
    
    -- Check size limit
    local count = 0
    for _ in pairs(store.data) do count = count + 1 end
    
    if count >= store.maxSize then
        -- Remove oldest entry (LRU)
        local oldestKey, oldestTime = nil, math.huge
        for k, v in pairs(store.data) do
            if v.lastAccess < oldestTime then
                oldestTime = v.lastAccess
                oldestKey = k
            end
        end
        if oldestKey then
            store.data[oldestKey] = nil
        end
    end
    
    store.data[key] = {
        value = value,
        time = os.clock(),
        lastAccess = os.clock()
    }
end

function Visual.Cache:Clear(storeName)
    if storeName then
        if self.stores[storeName] then
            self.stores[storeName].data = {}
        end
    else
        for _, store in pairs(self.stores) do
            store.data = {}
        end
    end
end

function Visual.Cache:GetStats(storeName)
    local store = self.stores[storeName]
    if not store then return nil end
    
    local count = 0
    for _ in pairs(store.data) do count = count + 1 end
    
    local hitRate = store.hits + store.misses > 0 
        and (store.hits / (store.hits + store.misses) * 100) 
        or 0
    
    return {
        entries = count,
        hits = store.hits,
        misses = store.misses,
        hitRate = hitRate,
        maxSize = store.maxSize
    }
end

