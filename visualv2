Visual._fovCircle = nil
Visual._fovVisible = false

function Visual.createFOVCircle()
    if Visual._fovCircle then return Visual._fovCircle end
    local ok, circle = pcall(function()
        local c = Drawing.new("Circle")
        c.Thickness = 1.5
        c.NumSides = 128
        c.Radius = 100
        c.Filled = false
        c.Visible = false
        c.Transparency = 0.8
        c.Color = Color3.fromRGB(200, 200, 255)
        return c
    end)
    if ok and circle then
        Visual._fovCircle = circle
        return circle
    end
    return nil
end

function Visual.updateFOVCircle(CFG, forceHide)
    local circle = Visual._fovCircle or Visual.createFOVCircle()
    if not circle then return end
    if forceHide or Visual.isOpen or not CFG.ShowFOV then
        circle.Visible = false
        Visual._fovVisible = false
        return
    end
    local cam = workspace.CurrentCamera
    if not cam then circle.Visible = false; return end
    local vp = cam.ViewportSize
    local centerX = vp.X * 0.5
    local centerY = vp.Y * 0.5
    local scale = math.min(vp.X, vp.Y) / 1080
    local radius = (CFG.FOVRadius or 100) * scale
    circle.Position = Vector2.new(centerX, centerY)
    circle.Radius = radius
    circle.NumSides = 128
    circle.Thickness = CFG.FOVThickness or 1.5
    if CFG.FOVMatchGUI then
        circle.Color = Visual.getColor(os.clock(), 0.5)
    else
        circle.Color = CFG.FOVColor or Color3.fromRGB(200, 200, 255)
    end
    circle.Transparency = CFG.FOVTransparency or 0.8
    circle.Visible = true
    Visual._fovVisible = true
end

function Visual.hideFOVCircle()
    if Visual._fovCircle then
        Visual._fovCircle.Visible = false
        Visual._fovVisible = false
    end
end

