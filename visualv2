-- ═══════════════════════════════════════════════════════
--  Main Render Loop — drives all per-frame updates:
--  FPS counter, clock, ping display, color engine
--  propagation, gradient sweeps, star twinkle animation,
--  rage overlay pulsing, and theme callback dispatch.
-- ═══════════════════════════════════════════════════════

_Renderer._updateConnection  = nil
_Renderer._lastFPSUpdate     = 0
_Renderer._frameCount        = 0
_Renderer._currentFPS        = 60
_Renderer._lastGradientSweep = 0

function _Renderer.startUpdateLoop()
    if _Renderer._updateConnection then return end

    _Renderer._updateConnection = _FrameService.RenderStepped:Connect(function()
        local _t = os.clock()

        -- ── FPS Counter ──
        _Renderer._frameCount = _Renderer._frameCount + 1
        if _t - _Renderer._lastFPSUpdate >= 1 then
            _Renderer._currentFPS   = _Renderer._frameCount
            _Renderer._frameCount   = 0
            _Renderer._lastFPSUpdate = _t
            if _Renderer.guiFPS then
                _Renderer.guiFPS.Text = _Renderer._currentFPS .. " fps"
            end
        end

        -- ── Clock Display ──
        if _Renderer.wmTime then
            _Renderer.wmTime.Text = os.date("%H:%M:%S")
        end

        -- ── Network Latency ──
        if _Renderer.guiPing then
            pcall(function()
                local _perfStats = game:GetService("Stats"):FindFirstChild("PerformanceStats")
                if _perfStats then
                    local _pingVal = _perfStats:FindFirstChild("Ping")
                    if _pingVal then
                        _Renderer.guiPing.Text = math.floor(_pingVal:GetValue()) .. "ms"
                    end
                end
            end)
        end

        -- ── Color Sequences ──
        local _seq   = _Renderer.getSequence(_t)
        local _stSeq = _Renderer.getStrokeSequence(_t)

        -- ── Throttled Gradient Sweep ──
        -- Updates all UIGradient descendants across both GUI trees.
        -- Throttled to ~12 Hz to balance visual smoothness with CPU cost.
        if (_t - (_Renderer._lastGradientSweep or 0)) >= 0.08 then
            _Renderer._lastGradientSweep = _t

            local _themePrefs  = _Renderer.UIConfigs
            local _isMinimal   = _themePrefs.ThemeMode == 5
            local _solidText   = ColorSequence.new(Color3.fromRGB(210, 215, 230))
            local _solidAccent = ColorSequence.new(Color3.fromRGB(90, 130, 220))
            local _solidStroke = ColorSequence.new(Color3.fromRGB(55, 60, 80))
            local _flatTrans   = NumberSequence.new(0)

            local function _sweepGradients(_root)
                if not _root then return end
                for _, _desc in ipairs(_root:GetDescendants()) do
                    if _desc:IsA("UIGradient") then
                        if _isMinimal then
                            _desc.Transparency = _flatTrans
                            if _desc.Parent and _desc.Parent:IsA("UIStroke") then
                                _desc.Color = _solidStroke
                            elseif _desc.Parent and (_desc.Parent:IsA("TextLabel") or _desc.Parent:IsA("TextButton")) then
                                _desc.Color = _solidText
                            else
                                _desc.Color = _solidAccent
                            end
                        else
                            -- Keep existing transparency, just update color
                            _desc.Transparency = _desc.Transparency
                            if _desc.Parent and _desc.Parent:IsA("UIStroke") then
                                _desc.Color = _stSeq
                            else
                                _desc.Color = _seq
                            end
                        end
                    end
                end
            end

            pcall(function()
                _sweepGradients(_Renderer.gui)
                _sweepGradients(_Renderer.screenGui)
            end)
        end

        -- ── Window Transparency ──
        local _uiAlpha = _Renderer.UIConfigs.UITransparency or 0.15
        pcall(function()
            if _Renderer.W then
                _Renderer.W.BackgroundTransparency = 0.08 + _uiAlpha * 0.5
            end
        end)

        -- ── Watermark Gradient Updates ──
        pcall(function()
            if _Renderer._wmGrad      then _Renderer._wmGrad.Color      = _seq end
            if _Renderer._wmStGrad    then _Renderer._wmStGrad.Color    = _seq end
            if _Renderer._wmTitleGrad then _Renderer._wmTitleGrad.Color = _seq end
            if _Renderer._wmTimeGrad  then _Renderer._wmTimeGrad.Color  = _seq end
        end)

        -- ── Window Stroke & Indicators ──
        pcall(function()
            if _Renderer._gStGrad    then _Renderer._gStGrad.Color    = _seq end
            if _Renderer._tabIndGrad then _Renderer._tabIndGrad.Color = _seq end
            if _Renderer._tLGrad     then _Renderer._tLGrad.Color     = _seq end
        end)

        -- ── Conditional Background Animation ──
        pcall(function()
            if _Renderer.UIConfigs.BackgroundAnimate then
                if _Renderer._mainGrad then _Renderer._mainGrad.Color = _seq end
            end
            if _Renderer.UIConfigs.TopBarAnimate then
                if _Renderer._titleBarGrad then _Renderer._titleBarGrad.Color = _seq end
                if _Renderer._tabBarGrad   then _Renderer._tabBarGrad.Color   = _seq end
            end
        end)

        -- ── Metric Label Gradients ──
        pcall(function()
            if _Renderer._fpsGrad    then _Renderer._fpsGrad.Color    = _seq end
            if _Renderer._killsGrad  then _Renderer._killsGrad.Color  = _seq end
            if _Renderer._pingGrad   then _Renderer._pingGrad.Color   = _seq end
            if _Renderer._statusGrad then _Renderer._statusGrad.Color = _seq end
        end)

        -- ── Header Button Gradients ──
        pcall(function()
            if _Renderer._moonBtnGrad    then _Renderer._moonBtnGrad.Color    = _seq end
            if _Renderer._moonBtnTxtGrad then _Renderer._moonBtnTxtGrad.Color = _seq end
            if _Renderer._closeBtnG      then _Renderer._closeBtnG.Color      = _seq end
            if _Renderer._minBtnG        then _Renderer._minBtnG.Color        = _seq end
        end)

        -- ── Keybind Panel Gradients ──
        pcall(function()
            if _Renderer._bindsGrad      then _Renderer._bindsGrad.Color      = _seq end
            if _Renderer._bfStGrad       then _Renderer._bfStGrad.Color       = _seq end
            if _Renderer._bindsTitleGrad then _Renderer._bindsTitleGrad.Color = _seq end
        end)

        -- ── HUD Panel Gradients ──
        pcall(function()
            if _Renderer._hudGrad   then _Renderer._hudGrad.Color   = _seq end
            if _Renderer._hudStGrad then _Renderer._hudStGrad.Color = _seq end
        end)

        -- ── Crescent Gradient ──
        pcall(function()
            if _Renderer._moonOuterGrad then _Renderer._moonOuterGrad.Color = _seq end
        end)

        -- ── Background Overlay Gradient ──
        pcall(function()
            if _Renderer._fullAuroraGrad then _Renderer._fullAuroraGrad.Color = _seq end
        end)

        -- ── Enhanced Mode Overlay Pulsing ──
        pcall(function()
            if _Renderer._rageOverlay and _Renderer.isRageMode then
                local _pulseSeq = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(
                        255,
                        math.floor(60 + math.sin(_t * 2) * 30),
                        math.floor(90 + math.cos(_t * 1.5) * 40)
                    )),
                    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(
                        math.floor(180 + math.sin(_t * 1.7) * 40),
                        50,
                        math.floor(150 + math.cos(_t * 2.1) * 50)
                    )),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(
                        255,
                        math.floor(120 + math.sin(_t * 2.5) * 60),
                        math.floor(120 + math.cos(_t * 1.3) * 50)
                    ))
                })
                local _overlayGrad = _Renderer._rageOverlay:FindFirstChildOfClass("UIGradient")
                if _overlayGrad then
                    _overlayGrad.Color    = _pulseSeq
                    _overlayGrad.Rotation = 45 + math.sin(_t * 0.5) * 30
                end
            end
        end)

        -- ── Star Twinkle Animation ──
        pcall(function()
            if _Renderer.guiStars then
                for _i, _star in ipairs(_Renderer.guiStars) do
                    if _star and _star.Parent then
                        _star.BackgroundTransparency = 0.5 + 0.3 * math.sin(_t * (1.2 + _i * 0.15) + _i)
                    end
                end
            end
        end)

        -- ── Theme Callback Dispatch ──
        for _, _cb in ipairs(_Renderer.themeCallbacks) do
            pcall(_cb)
        end
    end)
end

-- ═══════════════════════════════════════════════════════
--  Cleanup / Teardown — disconnects all event listeners,
--  removes all Drawing objects, destroys GUI trees,
--  cleans up post-processing effects, and restores
--  the default input state. Call this when the module
--  is being unloaded or replaced.
-- ═══════════════════════════════════════════════════════

_Renderer._allConnections = {}

function _Renderer.destroy()
    -- Disconnect the render loop
    if _Renderer._updateConnection then
        pcall(function() _Renderer._updateConnection:Disconnect() end)
        _Renderer._updateConnection = nil
    end

    -- Disconnect all managed event connections
    for _, _conn in ipairs(_Renderer._allConnections) do
        pcall(function() _conn:Disconnect() end)
    end
    _Renderer._allConnections = {}

    for _, _conn in ipairs(_Renderer._uiConnections) do
        pcall(function() _conn:Disconnect() end)
    end
    _Renderer._uiConnections = {}

    -- Remove all overlay Drawing objects
    _Renderer.removeAllESP()
    _Renderer.removeAllChams()

    if _Renderer._fovCircle then
        pcall(function() _Renderer._fovCircle:Remove() end)
        _Renderer._fovCircle = nil
    end

    -- Stop camera rotation
    _Renderer.stopRageSpin()

    -- Destroy GUI trees
    pcall(function()
        if _Renderer.screenGui then _Renderer.screenGui:Destroy() end
    end)
    pcall(function()
        if _Renderer.gui then _Renderer.gui:Destroy() end
    end)
    pcall(function()
        if _Renderer.blurMain then _Renderer.blurMain = nil end
    end)

    -- Clean up any leftover post-processing effects
    for _, _child in ipairs(_RenderEnv:GetChildren()) do
        if _child.Name:find("Moon") then
            pcall(function() _child:Destroy() end)
        end
    end

    -- Restore default input state
    pcall(function()
        _InputAdapter.MouseBehavior    = Enum.MouseBehavior.Default
        _InputAdapter.MouseIconEnabled = true
    end)

    -- Dispose cached audio objects
    pcall(function()
        for _, _snd in pairs(_audioCache) do
            pcall(function() _snd:Destroy() end)
        end
        _audioCache = {}
    end)

    -- Clear callback registry
    _Renderer.themeCallbacks = {}
    _Renderer.resetKillCount()

    -- Null out public methods to prevent post-destroy calls
    _Renderer.Notify   = function() end
    _Renderer.PlaySound = function() end
end

-- ═══════════════════════════════════════════════════════
--  Module Initialization — creates the viewport guide,
--  builds the preference and changelog tabs, starts
--  the render loop, shows the loading splash, and
--  displays a welcome notification after a brief delay.
-- ═══════════════════════════════════════════════════════

function _Renderer.init(_prefs, _connections)
    _connections = _connections or {}
    _Renderer._allConnections = _connections

    -- Initialize the viewport guide circle
    _Renderer.createFOVCircle()

    -- Build tab content
    _Renderer.buildUITab(_prefs, _connections)
    _Renderer.buildPatchTab()

    -- Start the per-frame update loop
    _Renderer.startUpdateLoop()

    -- Show animated loading splash
    _Renderer.showLoadingScreen()

    -- Welcome notification (delayed to appear after splash)
    task.delay(2.5, function()
        _Renderer.Notify("MOON", "v3.5 loaded successfully", 4)
    end)
end

end

