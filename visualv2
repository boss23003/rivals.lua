-- ═══════════════════════════════════════════════════════
--  Viewport scaling utilities — compute a responsive
--  scale factor based on the current camera viewport
--  relative to the reference 1920×1080 baseline.
--  Cached briefly to avoid redundant per-frame lookups.
-- ═══════════════════════════════════════════════════════

local _cachedScale, _scaleTimestamp = 1, 0

function _LayoutEngine.getScale()
    if os.clock() - _scaleTimestamp < 0.35 then
        return _cachedScale
    end
    local _cam = workspace.CurrentCamera
    if _cam then
        _cachedScale = math.clamp(
            math.min(_cam.ViewportSize.X / _REF_WIDTH, _cam.ViewportSize.Y / _REF_HEIGHT),
            0.4, 4
        )
    end
    _scaleTimestamp = os.clock()
    return _cachedScale
end

-- Scale a pixel value by the current viewport ratio
function _LayoutEngine.S(_val)
    return _val * _LayoutEngine.getScale()
end

-- Retrieve the current viewport dimensions
function _LayoutEngine.getVP()
    local _cam = workspace.CurrentCamera
    return _cam and _cam.ViewportSize or Vector2.new(_REF_WIDTH, _REF_HEIGHT)
end

-- Compute viewport center coordinates
function _LayoutEngine.getCenter()
    local _vp = _LayoutEngine.getVP()
    return _vp.X * 0.5, _vp.Y * 0.5
end

-- ═══════════════════════════════════════════════════════
--  Touch feedback — Material-design-inspired ripple
--  effect that expands from the interaction point on
--  any button press for visual confirmation
-- ═══════════════════════════════════════════════════════

function _LayoutEngine.Ripple(_target, _px, _py)
    if not _target or not _target.Parent then return end

    local _circle = Instance.new("Frame")
    _circle.BackgroundColor3      = Color3.new(1, 1, 1)
    _circle.BackgroundTransparency = 0.45
    _circle.BorderSizePixel       = 0
    _circle.ZIndex                = (_target.ZIndex or 1) + 5
    _circle.AnchorPoint           = Vector2.new(0.5, 0.5)
    _circle.Position              = UDim2.new(0, _px or 0, 0, _py or 0)
    _circle.Size                  = UDim2.new(0, 0, 0, 0)
    _circle.Parent                = _target

    Instance.new("UICorner", _circle).CornerRadius = UDim.new(1, 0)

    local _circleGrad = Instance.new("UIGradient")
    _circleGrad.Color    = _LayoutEngine.getAuroraSequence(os.clock())
    _circleGrad.Rotation = math.random(0, 360)
    _circleGrad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.55),
        NumberSequenceKeypoint.new(1, 0.15)
    })
    _circleGrad.Parent = _circle

    local _maxDim = math.max(_target.AbsoluteSize.X, _target.AbsoluteSize.Y) * 2.5
    local _expandAnim = _AnimationService:Create(
        _circle,
        TweenInfo.new(0.55, Enum.EasingStyle.Quint),
        {Size = UDim2.new(0, _maxDim, 0, _maxDim), BackgroundTransparency = 1}
    )
    _expandAnim:Play()
    _expandAnim.Completed:Connect(function()
        pcall(function() _circle:Destroy() end)
    end)
end

