function _Renderer.buildUITab(_prefs, _connections)
    local _pageIdx = 5

    _Renderer.makeSection(_pageIdx, "THEME")
    _Renderer.makeCycle(_pageIdx, "Theme Mode",
        {"Aurora", "Moon", "Classic", "Custom", "Clean"},
        "ThemeMode", _Renderer.UIConfigs,
        function(_idx)
            _Renderer.UIConfigs.ThemeMode = _idx
        end
    )
    _Renderer.makeToggle(_pageIdx, "Gradients", "GradientEnabled", _Renderer.UIConfigs, function() end)

    _Renderer.makeSection(_pageIdx, "COLORS")
    _Renderer.makeSlider(_pageIdx, "Color Speed",      "ColorSpeed",       0.05, 2,   0.05, _Renderer.UIConfigs, _connections)
    _Renderer.makeSlider(_pageIdx, "Intensity",         "ColorIntensity",   0.1,  2,   0.1,  _Renderer.UIConfigs, _connections)
    _Renderer.makeSlider(_pageIdx, "UI Transparency",   "UITransparency",   0,    0.9, 0.05, _Renderer.UIConfigs, _connections)
    _Renderer.makeSlider(_pageIdx, "Stroke Opacity",    "StrokeTransparency", 0,  1,   0.05, _Renderer.UIConfigs, _connections)

    _Renderer.makeSection(_pageIdx, "ANIMATION")
    _Renderer.makeToggle(_pageIdx, "Animate Background", "BackgroundAnimate", _Renderer.UIConfigs)
    _Renderer.makeToggle(_pageIdx, "Animate Top Bar",    "TopBarAnimate",     _Renderer.UIConfigs)
    _Renderer.makeCycle(_pageIdx, "Button Mode",
        {"Glow", "Gradient", "Hover", "Pulse"},
        "ButtonMode", _Renderer.UIConfigs
    )

    _Renderer.makeSection(_pageIdx, "CONFIG")

    local _statusLabel = _Renderer.makeLabel(_pageIdx)
    _statusLabel.Text     = ""
    _statusLabel.TextSize = 9

    _Renderer.makeButton(_pageIdx, "Export Config", function()
        local _str = _Renderer.ConfigSystem.Export(_prefs)
        if _str then
            pcall(function() if setclipboard then setclipboard(_str) end end)
            _statusLabel.Text = "Copied!"
            _Renderer.Notify("Config", "Exported to clipboard!", 3)
            task.delay(3, function()
                if _statusLabel and _statusLabel.Parent then
                    _statusLabel.Text = ""
                end
            end)
        end
    end)

    _Renderer.makeButton(_pageIdx, "Save to File", function()
        _Renderer.ConfigSystem.SaveToFile(_prefs, "moon_config")
        _Renderer.Notify("Config", "Saved to file!", 3)
    end)

    _Renderer.makeButton(_pageIdx, "Load from File", function()
        if _Renderer.ConfigSystem.LoadFromFile(_prefs, "moon_config") then
            _Renderer.Notify("Config", "Config loaded!", 3)
        else
            _Renderer.Notify("Config", "No config file found", 3, Color3.fromRGB(255, 100, 100))
        end
    end)

    -- Theme profile management
    _Renderer.makeSection(_pageIdx, "THEME PROFILES")

    local _profileStatus = _Renderer.makeLabel(_pageIdx)
    _profileStatus.TextSize = 9
    _profileStatus.Text     = "Select or create profile"

    local _profileNames = {}
    for _key, _prof in pairs(_Renderer.ThemeProfiles) do
        _profileNames[#_profileNames + 1] = _prof.Name or _key
    end
    table.sort(_profileNames)

    _Renderer.makeCycle(_pageIdx, "Active Profile", _profileNames,
        "_ActiveThemeProfile", _Renderer,
        function(_idx)
            local _name = _profileNames[_idx]
            if not _name then return end

            -- Find internal key matching the display name
            local _internalKey = nil
            for _key, _prof in pairs(_Renderer.ThemeProfiles) do
                if (_prof.Name or _key) == _name then
                    _internalKey = _key
                    break
                end
            end

            if _internalKey and _Renderer.ApplyThemeProfile(_internalKey) then
                _profileStatus.Text = "Applied: " .. _name
                _Renderer.SaveThemeProfiles()
            end
        end
    )

    _Renderer.makeButton(_pageIdx, "Save Current as Profile", function()
        local _baseName = "Custom " .. os.date("%H:%M:%S")
        _Renderer.CreateThemeProfile(_baseName)
        _profileStatus.Text = "Saved profile: " .. _baseName
        _Renderer.SaveThemeProfiles()
    end)

    _Renderer.makeButton(_pageIdx, "Reset to Aurora Default", function()
        if _Renderer.ApplyThemeProfile("AuroraDefault") then
            _profileStatus.Text = "Reset to Aurora Default"
            _Renderer.SaveThemeProfiles()
        end
    end)

    _Renderer.makeSection(_pageIdx, "INFO")
    _Renderer.makeInfo(_pageIdx, "MOON v3.5 — 5 themes available")
    _Renderer.makeInfo(_pageIdx, "Aurora / Moon / Classic / Custom / Clean")
    _Renderer.makeInfo(_pageIdx, "Clean = no gradients, solid colors")
    _Renderer.makeInfo(_pageIdx, "Intensity changes color brightness")
    _Renderer.makeInfo(_pageIdx, "UI Transparency changes window opacity")
end

