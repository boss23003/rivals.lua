function Visual.updateActiveBinds(CFG, C, aimActive, targetActive, spinActive, rageMode)
    local stateMap = {
        {"Aimbot",CFG.Enabled,"aim "..(CFG.Enabled and "on" or "off").." ("..tostring(CFG.AimKey or "?")..")"},
        {"Locking",aimActive,"aim lock ("..tostring(CFG.AimKey or "?")..")"},
        {"Target",targetActive,"target on ("..tostring(CFG.TargetKey or "?")..")"},
        {"Spin",spinActive,"spin on"}, {"Triggerbot",CFG.Triggerbot,"trigger on"},
        {"ESP",CFG.ShowESP,"esp on"}, {"Chams",CFG.ShowChams,"chams on"},
        {"Dash",CFG.DashEnabled,"dash ready ("..tostring(CFG.DashKey or "?")..")"},
        {"Rage",rageMode,rageMode and "rage mode enabled" or "rage mode disabled"},
        {"R.Dash",CFG.RageDash,"rage dash on"}, {"R.Target",CFG.RageTarget,"rage target on"}
    }
    for _, item in ipairs(stateMap) do
        local ck,cur = item[1],item[2]
        if Visual._bindsStateCache[ck] == nil then Visual._bindsStateCache[ck] = cur
        elseif Visual._bindsStateCache[ck] ~= cur then Visual._bindsStateCache[ck] = cur; if cur then Visual.pushBindEvent(item[3]) end end
    end
    for _, child in ipairs(bindsContent:GetChildren()) do if child:IsA("Frame") and child.Name == "BindStateRow" then child:Destroy() end end
    local items = {}
    local function add(n,a,k) items[#items+1] = {n=n,a=a,k=k or ""} end
    add("Aimbot",CFG.Enabled,CFG.AimKey)
    if aimActive then add("Locking",true,CFG.AimKey) end
    if targetActive then add("Target",true,CFG.TargetKey) end
    if spinActive then add("Spin",true,"") end
    add("Trigger",CFG.Triggerbot,""); add("ESP",CFG.ShowESP,""); add("Chams",CFG.ShowChams,"")
    add("Dash",CFG.DashEnabled,CFG.DashKey)
    if rageMode then add("Rage",true,"") end
    if CFG.RageDash then add("R.Dash",true,"") end
    if CFG.RageTarget then add("R.Target",true,"") end
    for index, item in ipairs(items) do
        local row = Instance.new("Frame"); row.Name = "BindStateRow"; row.Size = UDim2.new(1,0,0,18)
        row.BackgroundColor3 = Color3.new(1,1,1); row.BackgroundTransparency = 0.22; row.BorderSizePixel = 0
