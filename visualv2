local function _nextOrder(_pi)
    _pageOrders[_pi] = _pageOrders[_pi] + 1
    return _pageOrders[_pi]
end

-- Maps tab index to page index depending on mode
function _LayoutEngine.getMappedPage(_tabIdx, _enhanced)
    if _enhanced then return _tabIdx end
    if _tabIdx <= 2 then return _tabIdx end
    if _tabIdx == 3 then return 4 end
    if _tabIdx == 4 then return 5 end
    if _tabIdx == 5 then return 6 end
    return 7
end

-- Rebuild tab button strip for current mode
local function _rebuildTabButtons()
    for _, _btn in ipairs(_tabButtons) do
        if _btn then _btn:Destroy() end
    end
    table.clear(_tabButtons)

    _currentTabs = _isEnhancedMode and _LayoutEngine.RageTabs or _LayoutEngine.NormalTabs
    _LayoutEngine.TabNames = _currentTabs

    local _count = #_currentTabs
    local _btnWidth = math.floor(_winW / _count)

    for _i, _name in ipairs(_currentTabs) do
        local _btn = Instance.new("TextButton")
        _btn.Text                  = _name
        _btn.Size                  = UDim2.new(0, _btnWidth, 1, 0)
        _btn.Position              = UDim2.new(0, (_i - 1) * _btnWidth, 0, 0)
        _btn.BackgroundTransparency = 1
        _btn.TextColor3            = Color3.new(1, 1, 1)
        _btn.TextSize              = 11
        _btn.Font                  = Enum.Font.GothamBold
        _btn.BorderSizePixel       = 0
        _btn.AutoButtonColor       = false
        _btn.ZIndex                = 15
        _btn.Parent                = _tabStrip

        local _tbGrad = Instance.new("UIGradient")
        _tbGrad.Color = _LayoutEngine.getAuroraSequence(os.clock() + _i * 0.2)
        _tbGrad.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.02),
            NumberSequenceKeypoint.new(1, 0.14)
        })
        _tbGrad.Parent = _btn

        _btn.MouseEnter:Connect(function()
            if _activeTab ~= _i then
                _AnimationService:Create(_btn, TweenInfo.new(0.15), {TextTransparency = 0.1}):Play()
            end
        end)
        _btn.MouseLeave:Connect(function()
            if _activeTab ~= _i then
                _AnimationService:Create(_btn, TweenInfo.new(0.15), {TextTransparency = 0.35}):Play()
            end
        end)
        _btn.MouseButton1Click:Connect(function()
            _LayoutEngine.PlaySound("Tab", 0.22, 1.02)
            _activeTab = _i

            -- Switch page visibility
            for _pi = 1, 7 do
                _tabPages[_pi].Visible = false
            end
            _tabPages[_LayoutEngine.getMappedPage(_i, _isEnhancedMode)].Visible = true

            -- Update button text transparency
            for _bi, _bb in ipairs(_tabButtons) do
                _AnimationService:Create(
                    _bb,
                    TweenInfo.new(0.25, Enum.EasingStyle.Quint),
                    {TextTransparency = (_bi == _i) and 0 or 0.35}
                ):Play()
            end

            -- Slide indicator
            _AnimationService:Create(
                _tabIndicator,
                TweenInfo.new(0.35, Enum.EasingStyle.Quint),
                {
                    Position = UDim2.new(0, (_i - 1) * _btnWidth + 8, 1, -2),
                    Size     = UDim2.new(0, _btnWidth - 16, 0, 2)
                }
            ):Play()
        end)

        _btn.TextTransparency = _i == _activeTab and 0 or 0.35
        _tabButtons[_i] = _btn
    end

    -- Show active page
    for _pi = 1, 7 do _tabPages[_pi].Visible = false end
    _tabPages[_LayoutEngine.getMappedPage(_activeTab, _isEnhancedMode)].Visible = true

    -- Position indicator
    local _w = math.floor(_winW / #_currentTabs)
    _tabIndicator.Size     = UDim2.new(0, _w - 16, 0, 2)
    _tabIndicator.Position = UDim2.new(0, (_activeTab - 1) * _w + 8, 1, -2)
end

-- Toggle between standard and enhanced tab layouts
function _LayoutEngine.setRageMode(_state)
    _state = not not _state
    _isEnhancedMode = _state
    _LayoutEngine.isRageMode = _state

    _AnimationService:Create(
        _enhancedOverlay,
        TweenInfo.new(0.35, Enum.EasingStyle.Quint),
        {BackgroundTransparency = _state and 0.88 or 1}
    ):Play()
    _AnimationService:Create(
        _bgOverlay,
        TweenInfo.new(0.35, Enum.EasingStyle.Quint),
        {BackgroundTransparency = _state and 0.18 or 0.32}
    ):Play()

    _enhanceBtn.Text = _state and "RAGE ON" or "RAGE"
    _brandLabel.Text = _state and "MOON R" or "MOON"

    if _activeTab > #(_state and _LayoutEngine.RageTabs or _LayoutEngine.NormalTabs) then
        _activeTab = 1
    end

    _rebuildTabButtons()
end

_LayoutEngine.tPs         = _tabPages
_LayoutEngine.tBs         = _tabButtons
_LayoutEngine.refreshTabs = _rebuildTabButtons
_rebuildTabButtons()

