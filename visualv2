Visual.NotificationQueue = {
    queue = {},
    maxVisible = 5,
    spacing = 8
}

function Visual.NotificationQueue:Add(title, text, duration, color, priority)
    priority = priority or 0
    
    local notification = {
        title = Visual.Validate.String(title, "Notification", 50),
        text = Visual.Validate.String(text, "", 200),
        duration = Visual.Validate.Number(duration, 4, 1, 30),
        color = Visual.Validate.Color3(color, Visual.getAuroraColor(os.clock())),
        priority = priority,
        time = os.clock()
    }
    
    -- Insert based on priority
    local inserted = false
    for i, notif in ipairs(self.queue) do
        if notification.priority > notif.priority then
            table.insert(self.queue, i, notification)
            inserted = true
            break
        end
    end
    
    if not inserted then
        table.insert(self.queue, notification)
    end
    
    -- Limit queue size
    while #self.queue > 20 do
        table.remove(self.queue, 1)
    end
    
    self:Process()
end

function Visual.NotificationQueue:Process()
    -- Show top notifications
    local visible = 0
    for i, notif in ipairs(self.queue) do
        if visible < self.maxVisible then
            if not notif.shown then
                Visual.Notify(notif.title, notif.text, notif.duration, notif.color)
                notif.shown = true
                visible = visible + 1
            end
        end
    end
    
    -- Remove expired
    local now = os.clock()
    for i = #self.queue, 1, -1 do
        local notif = self.queue[i]
        if notif.shown and now - notif.time > notif.duration + 1 then
            table.remove(self.queue, i)
        end
    end
end

