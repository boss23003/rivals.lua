function _LayoutEngine.Notify(_heading, _body, _seconds, _accent)
    _seconds = _seconds or 4
    _accent  = _accent or _LayoutEngine.getColor(os.clock(), 0)

    _LayoutEngine.PlaySound("Notify", 0.24, 1.03)

    -- Card container
    local _card = Instance.new("Frame")
    _card.Size                  = UDim2.new(1, 0, 0, 60)
    _card.BackgroundColor3      = Color3.new(1, 1, 1)
    _card.BackgroundTransparency = 0.12
    _card.BorderSizePixel       = 0
    _card.ClipsDescendants      = true
    _card.ZIndex                = 201
    _card.Parent                = _toastContainer

    Instance.new("UICorner", _card).CornerRadius = UDim.new(0, 10)

    local _cardGrad = Instance.new("UIGradient")
    _cardGrad.Color    = _LayoutEngine.getAuroraSequence(os.clock())
    _cardGrad.Rotation = 18
    _cardGrad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.35),
        NumberSequenceKeypoint.new(1, 0.15)
    })
    _cardGrad.Parent = _card

    local _cardStroke = Instance.new("UIStroke")
    _cardStroke.Thickness    = 1.2
    _cardStroke.Transparency = 0.1
    _cardStroke.Parent       = _card

    local _cardStGrad = Instance.new("UIGradient")
    _cardStGrad.Color  = _LayoutEngine.getAuroraSequence(os.clock())
    _cardStGrad.Parent = _cardStroke

    -- Title line
    local _titleLine = Instance.new("TextLabel")
    _titleLine.Size                  = UDim2.new(1, -16, 0, 18)
    _titleLine.Position              = UDim2.new(0, 12, 0, 7)
    _titleLine.BackgroundTransparency = 1
    _titleLine.Text                  = _heading or ""
    _titleLine.TextColor3            = Color3.new(1, 1, 1)
    _titleLine.TextSize              = 12
    _titleLine.Font                  = Enum.Font.GothamBold
    _titleLine.TextXAlignment        = Enum.TextXAlignment.Left
    _titleLine.ZIndex                = 202
    _titleLine.Parent                = _card

    local _tStroke = Instance.new("UIStroke")
    _tStroke.Thickness    = 1.2
    _tStroke.Color        = Color3.new(0, 0, 0)
    _tStroke.Transparency = 0.15
    _tStroke.Parent       = _titleLine

    local _tGrad = Instance.new("UIGradient")
    _tGrad.Color  = _LayoutEngine.getAuroraSequence(os.clock())
    _tGrad.Parent = _titleLine

    -- Description line
    local _descLine = Instance.new("TextLabel")
    _descLine.Size                  = UDim2.new(1, -16, 0, 14)
    _descLine.Position              = UDim2.new(0, 12, 0, 29)
    _descLine.BackgroundTransparency = 1
    _descLine.Text                  = _body or ""
    _descLine.TextColor3            = Color3.new(1, 1, 1)
    _descLine.TextSize              = 10
    _descLine.Font                  = Enum.Font.Gotham
    _descLine.TextXAlignment        = Enum.TextXAlignment.Left
    _descLine.ZIndex                = 202
    _descLine.TextWrapped           = true
    _descLine.Parent                = _card

    local _dGrad = Instance.new("UIGradient")
    _dGrad.Color = _LayoutEngine.getAuroraSequence(os.clock() + 0.35)
    _dGrad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.1),
        NumberSequenceKeypoint.new(1, 0.35)
    })
    _dGrad.Parent = _descLine

    -- Progress bar at bottom
    local _progressBar = Instance.new("Frame")
    _progressBar.Size             = UDim2.new(1, 0, 0, 2)
    _progressBar.Position         = UDim2.new(0, 0, 1, -2)
    _progressBar.BorderSizePixel  = 0
    _progressBar.BackgroundColor3 = _accent
    _progressBar.ZIndex           = 202
    _progressBar.Parent           = _card

    local _pbGrad = Instance.new("UIGradient")
    _pbGrad.Color  = _LayoutEngine.getAuroraSequence(os.clock())
    _pbGrad.Parent = _progressBar

    -- Slide in from right
    _card.Position = UDim2.new(1, 60, 0, 0)
    _AnimationService:Create(
        _card,
        TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
        {Position = UDim2.new(0, 0, 0, 0)}
    ):Play()

    -- Progress bar shrink → then dismiss
    local _shrinkAnim = _AnimationService:Create(
        _progressBar,
        TweenInfo.new(_seconds, Enum.EasingStyle.Linear),
        {Size = UDim2.new(0, 0, 0, 2)}
    )
    _shrinkAnim:Play()
    _shrinkAnim.Completed:Connect(function()
        local _dismissAnim = _AnimationService:Create(
            _card,
            TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In),
            {Position = UDim2.new(1, 60, 0, 0), BackgroundTransparency = 1}
        )
        _dismissAnim:Play()
        _dismissAnim.Completed:Connect(function()
            pcall(function() _card:Destroy() end)
        end)
    end)
end

