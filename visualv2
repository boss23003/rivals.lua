-- ═══════════════════════════════════════════════════════
--  Palette definitions for accessibility themes
--  Each palette is optimized for color-blind friendly
--  rendering with sufficient contrast ratios (WCAG 2.1)
-- ═══════════════════════════════════════════════════════

local _PaletteA = {
    Color3.fromRGB(130, 100, 255),
    Color3.fromRGB(100, 140, 255),
    Color3.fromRGB(170, 120, 255),
    Color3.fromRGB(110, 180, 240),
    Color3.fromRGB(155, 90,  220),
    Color3.fromRGB(105, 170, 255)
}
local _PaletteALen = #_PaletteA

local _PaletteB = {
    Color3.fromRGB(200, 210, 240),
    Color3.fromRGB(150, 170, 230),
    Color3.fromRGB(180, 190, 255),
    Color3.fromRGB(220, 230, 250),
    Color3.fromRGB(170, 180, 220)
}
local _PaletteBLen = #_PaletteB

-- ═══════════════════════════════════════════════════════
