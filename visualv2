-- AUTOMATIC MAINTENANCE SYSTEM (32 lines)
-- ═══════════════════════════════════════════════════════════════

Visual.Maintenance = {
    lastCleanup = 0,
    cleanupInterval = 30,
    enabled = true
}

function Visual.Maintenance:Run()
    if not self.enabled then return end
    
    local now = os.clock()
    if now - self.lastCleanup < self.cleanupInterval then
        return
    end
    
    self.lastCleanup = now
    
    -- Process memory cleanup queue
    Visual.Memory:ProcessCleanup()
    
    -- Clear expired cache entries
    for storeName, store in pairs(Visual.Cache.stores) do
        local toRemove = {}
        for key, entry in pairs(store.data) do
            if now - entry.time > store.ttl then
                table.insert(toRemove, key)
            end
        end
        for _, key in ipairs(toRemove) do
            store.data[key] = nil
        end
    end
    
    -- Log maintenance
    print(string.format("[MOON] Maintenance: Memory=%d, Cache=%d stores", 
        Visual.Memory:GetStats().total,
        #Visual.Cache.stores
    ))
end

